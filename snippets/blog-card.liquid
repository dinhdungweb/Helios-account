<section class="helios-blog-banner {{ class }}" data-cc-animate="fade-up">
  <a href="{{ article.url }}" class="banner__image-link">
    {% if article.image %}
      <img 
        src="{{ article.image.src | image_url: width: 2000 }}" 
        alt="{{ article.title | escape }}" 
        loading="lazy" 
        width="2000" 
        height="{{ 2000 | divided_by: article.image.aspect_ratio | round }}"
        class="banner__image"
      >
    {% endif %}
  </a>
  
  <div class="banner__content">
    <div class="banner__meta">
      {{ article.tags | first | default: 'Journal' }} — {{ article.published_at | date: "%B %d, %Y" }}
    </div>
    <h2 class="banner__title">
      <a href="{{ article.url }}">{{ article.title }}</a>
    </h2>
    <a href="{{ article.url }}" class="banner__link">Read more</a>
  </div>
</section>
