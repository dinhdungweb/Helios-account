<style>
  .helios-blog-wrapper {
    background-color: #000000;
    color: #ffffff;
  }

  /* Full-width Banner Stack Layout */
  .helios-banner-stack {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 0 20px; /* Fixed 20px margin as requested */
    gap: 20px;
    margin-top: 0; /* Remove top margin */
  }

  /* Each Banner Section */
  .helios-blog-banner {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 500px;
    overflow: hidden;
    display: flex;
    /* align-items: center; removed */
    justify-content: center;
    border-radius: 0; /* Remove border radius */
  }

  .banner__image-link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7);
    /* Transition removed or kept for brightness only */
    transition: filter 0.5s ease;
  }

  .helios-blog-banner:hover .banner__image {
    /* Zoom effect removed */
    filter: brightness(0.6);
  }

  /* Centered Content Overlay */
  .banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    padding: 40px; /* Reset to 40px as requested */
    pointer-events: none;
  }

  .banner__title--small {
    font-size: 13px;
    font-weight: 400; /* Adjusted from 600 */
    letter-spacing: 0.1em; /* Adjusted from 0.2em */
    text-transform: uppercase;
    margin-bottom: 20px;
    opacity: 0.8;
  }

  .banner__title--small a {
    color: #fff;
    text-decoration: none;
    pointer-events: auto;
  }

  .banner__highlight {
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    line-height: 1.4; /* Increased to prevent accent cutting */
    font-weight: 600; /* Increased to 600 */
    text-transform: uppercase;
    margin-bottom: 10px; /* Reduced to 10px */
    letter-spacing: 0.02em;
    color: #fff;
    /* Improved 1-line truncation */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 10px 10px; /* Added padding to give space for marks */
  }

  .banner__link {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding-bottom: 5px;
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  /* Blog Page Header Navigation */
  .blog-page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 40px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .blog-page-header__title {
    font-size: 24px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
  }

  .blog-page-header__nav {
    display: flex;
    gap: 30px;
  }

  .blog-page-header__link {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.3s;
  }

  .blog-page-header__link:hover,
  .blog-page-header__link.is-active {
    color: #fff;
  }

  .banner__link:hover {
    border-bottom-color: #fff;
    letter-spacing: 0.25em;
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .helios-banner-stack {
      padding: 0 20px;
      gap: 20px;
    }
    .helios-blog-banner {
      height: 60vh;
    }
    .banner__title {
      font-size: 1.8rem;
    }
    .banner__meta {
      margin-bottom: 15px;
    }
  }
</style>
