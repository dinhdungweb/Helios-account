<style>
  :root {
    --blog-black: #000000;
    --blog-dark: #0A0A0A;
    --blog-gray: #1A1A1A;
    --blog-text: #FFFFFF;
    --blog-text-muted: #888888;
    --blog-accent: #C39D6F;
    --blog-border: rgba(255, 255, 255, 0.1);
  }

  .helios-blog-wrapper {
    background-color: var(--blog-black);
    color: var(--blog-text);
    font-family: 'Futura', sans-serif;
    overflow-x: hidden;
  }

  /* Hero Section */
  .helios-blog-hero {
    position: relative;
    height: 80vh;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 80px;
    background-color: #000;
  }

  .hero__image-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.6);
  }

  .hero__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, var(--blog-black), transparent);
  }

  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  .hero__meta {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: monospace;
    color: var(--blog-accent);
    align-items: center;
  }

  .hero__title {
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 700;
    margin-bottom: 25px;
    text-transform: uppercase;
    max-width: 900px;
  }
  
  .hero__title a { color: #fff; text-decoration: none; }

  .hero__excerpt {
    font-size: 18px;
    color: var(--blog-text-muted);
    margin-bottom: 35px;
    max-width: 600px;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 30px;
    background: #fff;
    color: #000;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .hero__btn:hover { background: var(--blog-accent); color: #fff; }

  /* Main Grid */
  .helios-blog-main {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 60px;
    padding: 60px 0;
  }

  .helios-grid { display: grid; gap: 40px; }
  .helios-grid--featured { grid-template-columns: repeat(2, 1fr); }
  .helios-grid--3-col { grid-template-columns: repeat(3, 1fr); }

  .helios-blog-section { margin-bottom: 80px; }

  .section__header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }

  .section__title {
    font-size: 24px;
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .section__line { flex-grow: 1; height: 1px; background: var(--blog-border); }

  /* Sidebar */
  .sidebar__sticky { position: sticky; top: 100px; }
  .sidebar__section { margin-bottom: 50px; }
  .sidebar__title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--blog-accent);
    display: inline-block;
  }

  .popular-list { display: flex; flex-direction: column; gap: 20px; }
  .popular-item { display: flex; gap: 15px; }
  .popular-item__img { width: 80px; flex-shrink: 0; }
  .popular-item__img img { width: 100%; aspect-ratio: 1; object-fit: cover; }
  .popular-item__info a {
    color: var(--blog-text);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.4;
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Article Card Styles */
  .helios-blog-card {
    background: var(--blog-dark);
    border: 1px solid var(--blog-border);
    transition: all 0.4s ease;
  }

  .helios-blog-card:hover { border-color: var(--blog-accent); transform: translateY(-5px); }
  .blog-card__image-wrapper { position: relative; overflow: hidden; aspect-ratio: 16/10; }
  .blog-card__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .helios-blog-card:hover .blog-card__image { transform: scale(1.05); }
  .blog-card__content { padding: 25px; }

  .blog-card__meta {
    display: flex;
    gap: 10px;
    font-family: monospace;
    font-size: 12px;
    color: var(--blog-accent);
    margin-bottom: 15px;
    text-transform: uppercase;
  }

  .blog-card__title { font-size: 18px; font-weight: 700; line-height: 1.4; margin-bottom: 15px; text-transform: uppercase; }
  .blog-card__title a { color: #fff; text-decoration: none; }

  .blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--blog-text-muted);
    text-decoration: none;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 700;
    margin-top: 10px;
  }

  .helios-blog-card:hover .blog-card__link { color: var(--blog-accent); }

  /* Responsive */
  @media (max-width: 1024px) {
    .helios-blog-main { grid-template-columns: 1fr; }
    .sidebar__sticky { position: static; }
  }

  @media (max-width: 768px) {
    .helios-blog-hero { height: 60vh; }
    .helios-grid--featured, .helios-grid--3-col { grid-template-columns: 1fr; }
    .section__header { flex-direction: column; align-items: flex-start; gap: 10px; }
    .section__line { display: none; }
  }
</style>
