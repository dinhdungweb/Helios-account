<style>
  :root {
    --blog-black: #000000;
    --blog-text: #FFFFFF;
    --blog-accent: #C39D6F;
    --blog-font: 'Futura', sans-serif;
  }

  .helios-blog-wrapper {
    background-color: var(--blog-black);
    color: var(--blog-text);
    font-family: var(--blog-font);
  }

  /* Full-width Banner Stack Layout */
  .helios-banner-stack {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 0 44px; /* Align with header margin */
    gap: 30px; /* Add space between banners */
    margin-top: 40px;
  }

  /* Each Banner Section */
  .helios-blog-banner {
    position: relative;
    width: 100%;
    height: 80vh; 
    min-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px; /* Optional: adds a refined touch */
  }

  .banner__image-link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7);
    transition: transform 1.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .helios-blog-banner:hover .banner__image {
    transform: scale(1.05);
    filter: brightness(0.6);
  }

  /* Centered Content Overlay */
  .banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 0 40px;
    pointer-events: none; /* Let the link through */
  }

  .banner__meta {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 25px;
    color: var(--blog-text);
    opacity: 0.8;
  }

  .banner__title {
    font-size: clamp(2rem, 5vw, 4.5rem);
    line-height: 1.1;
    font-weight: 400;
    text-transform: uppercase;
    margin-bottom: 30px;
    letter-spacing: 0.05em;
  }
  
  .banner__title a { 
    color: #fff; 
    text-decoration: none; 
    pointer-events: auto;
  }

  .banner__link {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    padding-bottom: 5px;
    transition: all 0.3s ease;
    pointer-events: auto;
  }

  .banner__link:hover {
    border-bottom-color: #fff;
    letter-spacing: 0.25em;
  }

  /* Responsive Adjustments */
  @media (max-width: 768px) {
    .helios-banner-stack {
      padding: 0 20px;
      gap: 20px;
    }
    .helios-blog-banner { height: 60vh; }
    .banner__title { font-size: 1.8rem; }
    .banner__meta { margin-bottom: 15px; }
  }

</style>



