<style>
  :root {
    --blog-black: #000000;
    --blog-dark: #0A0A0A;
    --blog-gray: #151515;
    --blog-text: #FFFFFF;
    --blog-text-muted: #888888;
    --blog-accent: #C39D6F;
    --blog-border: rgba(255, 255, 255, 0.05);
  }

  .helios-blog-wrapper {
    background-color: var(--blog-black);
    color: var(--blog-text);
    font-family: 'Futura', sans-serif;
    padding-bottom: 100px;
  }

  /* Bento Grid Container */
  .helios-bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 280px;
    gap: 15px;
    margin-top: 40px;
  }

  /* Bento Item Variants */
  .bento-item {
    background: var(--blog-gray);
    position: relative;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bento-item--large { grid-column: span 2; grid-row: span 2; }
  .bento-item--wide { grid-column: span 2; }
  .bento-item--tall { grid-row: span 2; }
  .bento-item--small { grid-column: span 1; grid-row: span 1; }

  /* Artistic Text Block */
  .bento-item--text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    border: 1px solid var(--blog-border);
  }

  .bento__number {
    font-size: 60px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.05);
    line-height: 1;
    margin-bottom: 20px;
  }

  .bento__quote {
    font-size: 18px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blog-accent);
  }

  /* Blog Card in Bento */
  .helios-blog-card {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .blog-card__image-link {
    flex-grow: 1;
    display: block;
    height: 100%;
  }

  .blog-card__image-wrapper {
    height: 100%;
    width: 100%;
    position: relative;
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s ease;
  }

  .bento-item:hover .blog-card__image {
    transform: scale(1.1);
  }

  .blog-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 25px;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    z-index: 2;
  }

  .blog-card__meta {
    font-family: monospace;
    font-size: 11px;
    color: var(--blog-accent);
    text-transform: uppercase;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .blog-card__title {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    text-transform: uppercase;
    margin: 0;
  }

  .bento-item--large .blog-card__title { font-size: 32px; }
  
  .blog-card__title a { color: #fff; text-decoration: none; }

  /* Section Headers */
  .bento-section-header {
    margin-top: 80px;
    margin-bottom: 30px;
    display: flex;
    align-items: baseline;
    gap: 20px;
  }

  .bento-section-header h2 {
    font-size: 40px;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0;
  }

  .bento-section-header .line {
    flex-grow: 1;
    height: 1px;
    background: var(--blog-border);
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .helios-bento-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .helios-bento-grid { 
      grid-template-columns: repeat(2, 1fr); 
      grid-auto-rows: 200px;
      gap: 10px;
    }
    .bento-item--large, .bento-item--wide { grid-column: span 2; }
    .bento-section-header h2 { font-size: 24px; }
  }
</style>


