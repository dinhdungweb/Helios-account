{% comment %}
  Snippet: Account Header Bar — Dashboard Layout
  Usage: {% render 'account-hero', customer: customer, tier: tier %}
{% endcomment %}

<header class="db-header">
  <div class="db-header-left">
    <button class="db-menu-toggle" id="dbMenuToggle" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <div>
      <h1 class="db-header-title">Tài khoản của tôi</h1>
      <p class="db-header-subtitle">Thông tin tài khoản & chương trình thành viên</p>
    </div>
  </div>
  <div class="db-header-right">
    <div class="db-header-user-info">
      <div class="db-header-user-name">{{ customer.name }}</div>
      <div class="db-header-user-email">{{ customer.email }}</div>
    </div>
    <div class="db-header-avatar" style="background-image: url('https://cdn.shopify.com/s/files/1/0644/2958/8701/files/464413022_945803257578038_2084379289906124096_n.jpg?v=1764122552');"></div>
  </div>
</header>
