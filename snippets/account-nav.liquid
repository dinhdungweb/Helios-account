{%- liquid
  assign is_account_page = false
  if template == 'customers/account'
    assign is_account_page = true
  endif
-%}

<div class="db-sidebar-overlay" id="sidebarOverlay"></div>

<aside class="db-sidebar" id="dbSidebar">
  <div class="db-sidebar-logo">
    {% if settings.account_sidebar_logo != blank %}
      <img src="{{ settings.account_sidebar_logo | image_url: width: settings.account_sidebar_logo_width }}" alt="{{ shop.name }}" style="max-width: {{ settings.account_sidebar_logo_width }}px; height: auto;">
    {% else %}
      <h2>HELIOS</h2>
      <span>Silver Jewelry</span>
    {% endif %}
  </div>

  <nav class="db-sidebar-nav">
    <a class="db-nav-item {% if template == 'customers/account' %}active{% endif %}" {% if is_account_page %}data-scroll="top" href="#"{% else %}href="{{ routes.account_url }}"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="7" height="7"></rect>
        <rect x="14" y="3" width="7" height="7"></rect>
        <rect x="14" y="14" width="7" height="7"></rect>
        <rect x="3" y="14" width="7" height="7"></rect>
      </svg>
      Dashboard
    </a>

    <a class="db-nav-item" {% if is_account_page %}data-scroll="section-account" href="#"{% else %}href="{{ routes.account_url }}#section-account"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      My Account
    </a>

    <a class="db-nav-item" {% if is_account_page %}data-scroll="section-orders" href="#"{% else %}href="{{ routes.account_url }}#section-orders"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      Orders
    </a>

    <a class="db-nav-item" {% if is_account_page %}data-scroll="section-community" href="#"{% else %}href="{{ routes.account_url }}#section-community"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
      Cộng Đồng
    </a>

    <a class="db-nav-item" {% if is_account_page %}data-scroll="section-products" href="#"{% else %}href="{{ routes.account_url }}#section-products"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line>
      </svg>
      Sản Phẩm Member
    </a>

    <a class="db-nav-item" {% if is_account_page %}data-scroll="section-blacksun" href="#"{% else %}href="{{ routes.account_url }}#section-blacksun"{% endif %}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      Blacksun Club
    </a>

    <a class="db-nav-item {% if template == 'customers/addresses' %}active{% endif %}" href="{{ routes.account_addresses_url }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      Addresses
    </a>

    {% comment %}Render Custom Tabs from Blocks{% endcomment %}
    {% for block in section.blocks %}
      {% if block.type == 'custom_tab' %}
        {% if block.settings.enable_link and block.settings.tab_url != blank %}
          <a class="db-nav-item" href="{{ block.settings.tab_url }}" {% if block.settings.open_in_new_tab %}target="_blank"{% endif %}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            {{ block.settings.title }}
          </a>
        {% else %}
          <a class="db-nav-item" {% if is_account_page %}data-scroll="custom-tab-{{ block.id }}" href="#"{% else %}href="{{ routes.account_url }}#custom-tab-{{ block.id }}"{% endif %}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
            </svg>
            {{ block.settings.title }}
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </nav>

  <div class="db-sidebar-support">
    <div class="db-support-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 18v-6a9 9 0 0 1 18 0v6"></path>
        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path>
      </svg>
    </div>
    <h4>Cần hỗ trợ?</h4>
    <p>Đội ngũ HELIOS luôn sẵn sàng hỗ trợ bạn.</p>
    <a href="https://www.facebook.com/Official.Heliosvn" target="_blank" class="db-support-btn">Liên hệ ngay</a>
  </div>

  <div class="db-sidebar-footer">
    <a href="{{ routes.account_logout_url }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
        <polyline points="16 17 21 12 16 7"></polyline>
        <line x1="21" y1="12" x2="9" y2="12"></line>
      </svg>
      Đăng Xuất
    </a>
  </div>
</aside>
