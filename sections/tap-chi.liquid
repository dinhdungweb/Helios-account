<style>
  /* Chỉ giữ lại các style đặc thù cho tap-chi.liquid nếu có */
  .helios-blog-nav {
    background: var(--blog-black);
    border-bottom: 1px solid var(--blog-border);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 20px 0;
  }

  .blog-nav__list {
    display: flex;
    gap: 30px;
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .blog-nav__list::-webkit-scrollbar { display: none; }

  .blog-nav__list li a {
    color: var(--blog-text-muted);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 0.1em;
    white-space: nowrap;
    transition: color 0.3s;
  }

  .blog-nav__list li.active a,
  .blog-nav__list li a:hover {
    color: var(--blog-text);
  }

  .section__more {
    color: var(--blog-accent);
    text-decoration: underline;
    font-size: 13px;
    text-transform: uppercase;
    white-space: nowrap;
  }
</style>


{% schema %}
  {
    "name": "Tap chi (Blog)",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Section Title",
        "default": "Tạp chí"
      }
    ]
  }
{% endschema %}
