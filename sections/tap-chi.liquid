{%- liquid
  assign blog_handles = 'nhan,day-chuyen,khuyen,vong-tay,bac,trang-suc,da,kinh,qua,phu-kien,collab' | split: ','
  assign featured_tag = 'featured'
  
  # Tìm bài viết nổi bật nhất (mới nhất có tag featured hoặc đơn giản là mới nhất)
  assign featured_article = nil
  for handle in blog_handles
    assign b = blogs[handle]
    for a in b.articles
      if a.tags contains featured_tag
        assign featured_article = a
        break
      endif
    endfor
    if featured_article
      break
    endif
  endfor
  
  if featured_article == nil
    assign featured_article = blogs['nhan'].articles | first
  endif
-%}

<div class="helios-blog-wrapper" data-section-id="{{ section.id }}">
  <!-- Background Text -->
  <div class="blog-bg-text">HELIOS</div>

  <!-- Hero Section -->
  {% if featured_article %}
    <section class="helios-blog-hero">
      <div class="hero__image-container">
        {% if featured_article.image %}
          <img src="{{ featured_article.image.src | image_url: width: 1920 }}" alt="{{ featured_article.title | escape }}" class="hero__image" loading="eager">
        {% endif %}
      </div>
      <div class="hero__content">
        <div class="hero__meta" data-cc-animate="fade-in">
          <span class="hero__tag">{{ featured_article.tags | first }}</span>
          <span>•</span>
          <span class="hero__date">{{ featured_article.published_at | date: "%d.%m.%Y" }}</span>
        </div>
        <h1 class="hero__title" data-cc-animate="fade-up">
          <a href="{{ featured_article.url }}">{{ featured_article.title }}</a>
        </h1>
        <a href="{{ featured_article.url }}" class="hero__btn" data-cc-animate="fade-up" data-cc-animate-delay="0.2s">
          Vào trang lưu trữ
        </a>
      </div>
    </section>
  {% endif %}

  <!-- Main Content - Asymmetric Grid -->
  <main class="helios-blog-main">
    <div class="wide-container">
      
      <!-- Section 1: Latest -->
      <div class="helios-grid--asymmetric">
        <header class="section__header">
          <h2 class="section__title">Ấn phẩm mới nhất</h2>
        </header>

        {% assign count = 0 %}
        {% for handle in blog_handles %}
          {% for article in blogs[handle].articles %}
            {% if article.id != featured_article.id %}
              <div class="grid-item" data-cc-animate="fade-up">
                {% render 'blog-card', article: article %}
              </div>
              {% assign count = count | plus: 1 %}
            {% endif %}
            {% if count >= 12 %}{% break %}{% endif %}
          {% endfor %}
          {% if count >= 12 %}{% break %}{% endif %}
        {% endfor %}
      </div>

      <!-- Banner Break -->
      <section class="helios-blog-ad" style="margin: 150px 0;">
        <a href="{{ routes.all_products_collection_url }}">
          <img src="//helios.vn/cdn/shop/files/banner_helios_24.10-01_1.gif?v=1730360013" alt="HELIOS JEWELS" loading="lazy" style="width: 100%; filter: brightness(0.8);">
        </a>
      </section>

      <!-- Section 2: Selected Categories -->
      <div class="helios-grid--asymmetric">
        <header class="section__header">
          <h2 class="section__title">Bộ sưu tập Nhẫn</h2>
        </header>
        {% for article in blogs['nhan'].articles limit: 6 %}
          <div class="grid-item" data-cc-animate="fade-up">
            {% render 'blog-card', article: article %}
          </div>
        {% endfor %}
      </div>

    </div>
  </main>
</div>


{% render 'blog-styles-helper' %}

