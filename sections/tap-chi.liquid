{%- liquid
  assign blog_handles = 'nhan,day-chuyen,khuyen,vong-tay,bac,trang-suc,da,kinh,qua,phu-kien,collab' | split: ','
  assign featured_tag = 'featured'
  
  # Tìm bài viết nổi bật nhất (mới nhất có tag featured hoặc đơn giản là mới nhất)
  assign featured_article = nil
  for handle in blog_handles
    assign b = blogs[handle]
    for a in b.articles
      if a.tags contains featured_tag
        assign featured_article = a
        break
      endif
    endfor
    if featured_article
      break
    endif
  endfor
  
  if featured_article == nil
    assign featured_article = blogs['nhan'].articles | first
  endif
-%}

<div class="helios-blog-wrapper" data-section-id="{{ section.id }}">
  <div class="wide-container">
    
    <header class="bento-section-header">
      <h2>Chronicle</h2>
      <div class="line"></div>
      <div class="bento-meta">JOURNAL BY HELIOS</div>
    </header>

    <div class="helios-bento-grid">
      {% assign all_articles = blogs['nhan'].articles | concat: blogs['tin-tuc'].articles %}
      
      <!-- Article 1: Large -->
      <div class="bento-item bento-item--large">
        {% render 'blog-card', article: all_articles[0] %}
      </div>

      <!-- Artistic Block 1 -->
      <div class="bento-item bento-item--text">
        <div class="bento__number">01</div>
        <div class="bento__quote">Chế tác thủ công</div>
      </div>

      <!-- Article 2: Small -->
      <div class="bento-item bento-item--small">
        {% render 'blog-card', article: all_articles[1] %}
      </div>

      <!-- Article 3: Tall -->
      <div class="bento-item bento-item--tall">
        {% render 'blog-card', article: all_articles[2] %}
      </div>

      <!-- Article 4: Wide -->
      <div class="bento-item bento-item--wide">
        {% render 'blog-card', article: all_articles[3] %}
      </div>

      <!-- Artistic Block 2 -->
      <div class="bento-item bento-item--text">
        <div class="bento__number">02</div>
        <div class="bento__quote">Độc bản & Cá tính</div>
      </div>

      <!-- Article 5: Small -->
      <div class="bento-item bento-item--small">
        {% render 'blog-card', article: all_articles[4] %}
      </div>

      <!-- Article 6: Wide -->
      <div class="bento-item bento-item--wide">
        {% render 'blog-card', article: all_articles[5] %}
      </div>

      <!-- Article 7: Small -->
      <div class="bento-item bento-item--small">
        {% render 'blog-card', article: all_articles[6] %}
      </div>

      <!-- Article 8: Small -->
      <div class="bento-item bento-item--small">
        {% render 'blog-card', article: all_articles[7] %}
      </div>
    </div>

    <!-- Second Section: Catalog -->
    <header class="bento-section-header">
      <h2>Nhẫn</h2>
      <div class="line"></div>
    </header>

    <div class="helios-bento-grid">
      {% for article in blogs['nhan'].articles limit: 6 %}
        <div class="bento-item {% if forloop.first %}bento-item--wide{% else %}bento-item--small{% endif %}">
          {% render 'blog-card', article: article %}
        </div>
      {% endfor %}
    </div>

  </div>
</div>



{% render 'blog-styles-helper' %}

