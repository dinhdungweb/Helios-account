{% comment %}
  Timeline Section - Shopify Liquid
  Zigzag dashed lines drawn via JS SVG overlay
{% endcomment %}

<section class="tl-section" id="tl-{{ section.id }}">
  <div class="tl-overlay"></div>

  <div class="tl-container">
    {% if section.settings.heading != blank %}
      <h2 class="tl-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="tl-track" id="tl-track-{{ section.id }}">
      <!-- SVG lines injected by JS -->
      <svg class="tl-svg" id="tl-svg-{{ section.id }}" aria-hidden="true"></svg>

      {% for block in section.blocks %}
        {% assign is_right = forloop.index | modulo: 2 %}
        <div
          class="tl-item {% if is_right == 0 %}tl-item--right{% else %}tl-item--left{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="tl-dot" data-tl-dot></div>
          <div class="tl-content">
            {% if block.settings.date != blank %}
              <span class="tl-date">{{ block.settings.date }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="tl-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="tl-desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #tl-{{ section.id }} {
    --tl-bg:      {{ section.settings.bg_color }};
    --tl-dot:     {{ section.settings.dot_color }};
    --tl-line:    {{ section.settings.line_color }};
    --tl-text:    {{ section.settings.text_color }};
    --tl-date-cl: {{ section.settings.date_color }};
    --tl-dot-sz:  52px;
  }

  .tl-section {
    position: relative;
    padding: 80px 24px 100px;
    overflow: hidden;
    background-color: var(--tl-bg);
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: "master" }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .tl-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});
    pointer-events: none;
    z-index: 0;
  }

  .tl-container {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .tl-heading {
    text-align: center;
    color: var(--tl-text);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 56px;
  }

  /* Track: relative so SVG overlay positions correctly */
  .tl-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* SVG stretches to cover whole track */
  .tl-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
    z-index: 0;
  }

  .tl-item {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .tl-item--left {
    flex-direction: row;
    padding-right: 45%;
  }

  .tl-item--right {
    flex-direction: row-reverse;
    padding-left: 45%;
    text-align: right;
  }

  .tl-dot {
    flex-shrink: 0;
    width: var(--tl-dot-sz);
    height: var(--tl-dot-sz);
    border-radius: 50%;
    border: 3px solid var(--tl-dot);
    background: transparent;
    box-sizing: border-box;
    transition: background 0.3s;
  }

  .tl-item:hover .tl-dot {
    background: rgba(255,255,255,0.12);
  }

  .tl-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tl-date {
    color: var(--tl-date-cl);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .tl-title {
    color: var(--tl-text);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .tl-desc {
    color: var(--tl-text);
    font-size: 0.88rem;
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
  }

  /* Mobile: stack vertically, hide SVG, use simple pseudo-line */
  @media (max-width: 600px) {
    .tl-item--left,
    .tl-item--right {
      flex-direction: row;
      padding-left: 0;
      padding-right: 0;
      text-align: left;
    }
    .tl-svg {
      display: none;
    }
    .tl-item:not(:last-child) {
      padding-bottom: 32px;
    }
    .tl-item:not(:last-child) .tl-dot {
      position: relative;
    }
    .tl-item:not(:last-child) .tl-dot::after {
      content: '';
      position: absolute;
      left: 50%;
      top: 100%;
      transform: translateX(-50%);
      width: 0;
      height: 32px;
      border-left: 3px dashed var(--tl-line);
    }
  }
</style>

<script>
(function () {
  var SID = '{{ section.id }}';

  function drawLines() {
    var track = document.getElementById('tl-track-' + SID);
    var svg   = document.getElementById('tl-svg-'   + SID);
    if (!track || !svg) return;

    // Skip on mobile (SVG is hidden anyway)
    if (window.innerWidth <= 600) { svg.innerHTML = ''; return; }

    var dots = track.querySelectorAll('[data-tl-dot]');
    if (dots.length < 2) return;

    var trackRect = track.getBoundingClientRect();

    // Center of each dot relative to the track element
    var pts = Array.from(dots).map(function (dot) {
      var r = dot.getBoundingClientRect();
      return (r.left - trackRect.left + r.width / 2).toFixed(1) + ','
           + (r.top  - trackRect.top  + r.height / 2).toFixed(1);
    }).join(' ');

    // Read --tl-line CSS variable for colour
    var color = getComputedStyle(track.closest('[id^="tl-"]'))
                  .getPropertyValue('--tl-line').trim() || '#ffffff';

    svg.innerHTML =
      '<polyline' +
        ' points="'        + pts     + '"' +
        ' fill="none"' +
        ' stroke="'        + color   + '"' +
        ' stroke-width="2.5"' +
        ' stroke-dasharray="8 6"' +
        ' stroke-linecap="round"' +
      '/>';
  }

  function init() {
    drawLines();
    window.addEventListener('resize', drawLines);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    // Slight delay so Shopify editor reflow finishes
    setTimeout(init, 120);
  }
})();
</script>

{% schema %}
{
  "name": "Timeline",
  "tag": "section",
  "class": "section-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề section",
      "default": "Lộ trình phát triển"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Ảnh nền (Background Image)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền (nếu không có ảnh)",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Độ tối overlay trên ảnh nền",
      "default": 55
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Màu dot",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Màu đường dashed",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Màu ngày tháng",
      "default": "#cccccc"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Mốc thời gian",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Ngày / Tháng",
          "default": "23/03/2026"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tiêu đề",
          "default": "Ra mắt BST đầu tiên"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Mô tả (tuỳ chọn)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "date": "23/03/2026",
            "title": "Ra mắt BST đầu tiên"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 5/2026",
            "title": "BST thứ hai"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 9/2026",
            "title": "Ra mắt sản phẩm ..."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 10/2026",
            "title": "Ra mắt sản phẩm"
          }
        }
      ]
    }
  ]
}
{% endschema %}
