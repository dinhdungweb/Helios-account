{% comment %}
  Timeline Section - Shopify Liquid
  Dark industrial aesthetic with zigzag dashed line
{% endcomment %}

<section class="timeline-section" id="timeline-{{ section.id }}">
  <div class="timeline-bg-overlay"></div>

  <div class="timeline-container">
    {% if section.settings.heading != blank %}
      <h2 class="timeline-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="timeline-track">
      {% for block in section.blocks %}
        {% assign is_right = forloop.index | modulo: 2 %}
        <div
          class="timeline-item {% if is_right == 0 %}timeline-item--right{% else %}timeline-item--left{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="timeline-dot">
            <span class="timeline-dot__inner"></span>
          </div>
          <div class="timeline-content">
            {% if block.settings.date != blank %}
              <span class="timeline-date">{{ block.settings.date }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h3 class="timeline-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="timeline-desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* ── Variables ── */
  #timeline-{{ section.id }} {
    --tl-bg:        {{ section.settings.bg_color }};
    --tl-dot:       {{ section.settings.dot_color }};
    --tl-line:      {{ section.settings.line_color }};
    --tl-text:      {{ section.settings.text_color }};
    --tl-date:      {{ section.settings.date_color }};
    --tl-dot-size:  52px;
    --tl-gap:       64px;
  }

  /* ── Section wrapper ── */
  .timeline-section {
    position: relative;
    padding: 80px 24px;
    overflow: hidden;
    background-color: var(--tl-bg);
    {% if section.settings.bg_image != blank %}
      background-image: url('{{ section.settings.bg_image | img_url: "master" }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .timeline-bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    pointer-events: none;
    z-index: 0;
  }

  /* ── Container ── */
  .timeline-container {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
  }

  .timeline-heading {
    text-align: center;
    color: var(--tl-text);
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 56px;
  }

  /* ── Track ── */
  .timeline-track {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Draw the zigzag dashed SVG line behind items ── */
  .timeline-track::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Each item ── */
  .timeline-item {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 12px 0;
    min-height: calc(var(--tl-dot-size) + 40px);
  }

  /* LEFT item: dot on left, content on right */
  .timeline-item--left {
    flex-direction: row;
    padding-left: 0;
    padding-right: 40%;
  }

  /* RIGHT item: content on left side (mirrored), dot on right */
  .timeline-item--right {
    flex-direction: row-reverse;
    padding-right: 0;
    padding-left: 40%;
    text-align: right;
  }

  /* ── Dot ── */
  .timeline-dot {
    flex-shrink: 0;
    width: var(--tl-dot-size);
    height: var(--tl-dot-size);
    border-radius: 50%;
    border: 3px solid var(--tl-dot);
    background: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .timeline-dot__inner {
    width: calc(var(--tl-dot-size) * 0.35);
    height: calc(var(--tl-dot-size) * 0.35);
    border-radius: 50%;
    background: var(--tl-dot);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .timeline-item:hover .timeline-dot__inner {
    opacity: 1;
  }

  /* ── Content ── */
  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .timeline-date {
    color: var(--tl-date);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .timeline-title {
    color: var(--tl-text);
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .timeline-desc {
    color: var(--tl-text);
    font-size: 0.9rem;
    opacity: 0.7;
    margin: 0;
    line-height: 1.5;
  }

  /* ── Zigzag connector lines via SVG overlay ── */
  .timeline-track {
    --dot-half: calc(var(--tl-dot-size) / 2);
  }

  /* We draw lines between dots using pseudo-elements on the items */
  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    bottom: calc(-1 * var(--tl-gap) / 2 - var(--tl-dot-size) / 2 + 6px);
    width: 2px;
    height: var(--tl-gap);
    background: transparent;
    border-left: 3px dashed var(--tl-line);
    z-index: 0;
    transform-origin: top center;
  }

  /* Line from LEFT item's dot to next RIGHT item's dot — goes down-right */
  .timeline-item--left:not(:last-child)::after {
    left: calc(var(--tl-dot-size) / 2 - 1px);
    transform: rotate(25deg);
  }

  /* Line from RIGHT item's dot to next LEFT item's dot — goes down-left */
  .timeline-item--right:not(:last-child)::after {
    right: calc(var(--tl-dot-size) / 2 - 1px);
    left: auto;
    border-left: none;
    border-right: 3px dashed var(--tl-line);
    transform: rotate(-25deg);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .timeline-item--left,
    .timeline-item--right {
      flex-direction: row;
      padding-left: 0;
      padding-right: 0;
      text-align: left;
    }

    .timeline-item--left:not(:last-child)::after,
    .timeline-item--right:not(:last-child)::after {
      left: calc(var(--tl-dot-size) / 2 - 1px);
      right: auto;
      border-left: 3px dashed var(--tl-line);
      border-right: none;
      transform: none;
    }

    .timeline-heading {
      font-size: 1.4rem;
    }
  }
</style>

{% schema %}
{
  "name": "Timeline",
  "tag": "section",
  "class": "section-timeline",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề section",
      "default": "Lộ trình phát triển"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Ảnh nền (Background Image)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền (nếu không có ảnh)",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Độ tối overlay trên ảnh nền",
      "default": 55
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Màu dot",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Màu đường dashed",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Màu ngày tháng",
      "default": "#cccccc"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Mốc thời gian",
      "settings": [
        {
          "type": "text",
          "id": "date",
          "label": "Ngày / Tháng",
          "default": "23/03/2026"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tiêu đề",
          "default": "Ra mắt BST đầu tiên"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Mô tả (tuỳ chọn)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "date": "23/03/2026",
            "title": "Ra mắt BST đầu tiên"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 5/2026",
            "title": "BST thứ hai"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 9/2026",
            "title": "Ra mắt sản phẩm ..."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "date": "Tháng 10/2026",
            "title": "Ra mắt sản phẩm"
          }
        }
      ]
    }
  ]
}
{% endschema %}
