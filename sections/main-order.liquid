{{ 'account.css' | asset_url | stylesheet_tag: preload: true }}

<div class="db-wrapper">
  {% render 'account-nav' %}

  <div class="db-main">
    {% render 'account-hero', customer: customer %}

    <div class="db-content">
      <div class="db-card">
        <div class="db-card-header" style="justify-content: space-between;">
          <h3 class="db-card-title">{{ 'customer.order.title' | t: name: order.name }}</h3>
          <span class="db-status-badge {{ order.financial_status }}">{{ order.financial_status_label }}</span>
        </div>

        <div class="db-card-body">
          <div class="db-address-page-header">
            <a href="{{ routes.account_url }}" class="db-back-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
              </svg>
              Quay lại danh sách đơn hàng
            </a>
          </div>

          {% if order.cancelled %}
          <div id="order_cancelled" class="db-alert db-alert-error" style="margin-bottom: 20px;">
            {% assign date = order.cancelled_at | date: format: "month_date_year" %}
            <h5 id="order_cancelled_title" style="margin:0 0 5px; font-weight:700;">{{ 'customer.order.cancelled_on' | t: date: date }}</h5>
            <span class="note">{{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason }}</span>
          </div>
          {% endif %}

          {% assign date = order.created_at | date: format: "month_date_year" %}
          <div class="db-order-date-label" style="font-size:13px; color:var(--db-text-muted); margin-bottom: 20px;">
            {{ 'customer.order.date' | t: date: date }}
          </div>

          <div class="db-order-addresses-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
            <div class="db-address-block" style="background: var(--db-surface-2); padding: 15px; border: 1px solid var(--db-border);">
              <h5 class="db-address-block-title" style="margin: 0 0 10px; font-size:12px; font-weight:700; text-transform:uppercase; color:var(--db-accent);">{{ 'customer.order.billing_address' | t }}</h5>
              <div class="address-details" style="font-size:13px; color:var(--db-text-2); line-height: 1.6;">
                <p style="margin:0 0 4px; font-weight:600; color:var(--db-text);">{{ order.billing_address.name }}</p>
                {% if order.billing_address.company != blank %}<p style="margin:0 0 4px;">{{ order.billing_address.company }}</p>{% endif %}
                <p style="margin:0 0 4px;">{{ order.billing_address.street }}</p>
                <p style="margin:0 0 4px;">{{ order.billing_address.city }}, {{ order.billing_address.province }}</p>
                <p style="margin:0 0 4px;">{{ order.billing_address.country }} {{ order.billing_address.zip }}</p>
                {% if order.billing_address.phone != blank %}<p style="margin:0;">{{ order.billing_address.phone }}</p>{% endif %}
              </div>
            </div>
            
            {% if order.shipping_address %}
            <div class="db-address-block" style="background: var(--db-surface-2); padding: 15px; border: 1px solid var(--db-border);">
              <h5 class="db-address-block-title" style="margin: 0 0 10px; font-size:12px; font-weight:700; text-transform:uppercase; color:var(--db-accent);">{{ 'customer.order.shipping_address' | t }}</h5>
              <p style="font-size:11px; margin:0 0 8px;"><span style="color:var(--db-text-muted);">Trạng thái giao hàng:</span> <span class="db-status-badge {{ order.fulfillment_status }}" style="margin-left:4px;">{{ order.fulfillment_status_label }}</span></p>
              <div class="address-details" style="font-size:13px; color:var(--db-text-2); line-height: 1.6;">
                <p style="margin:0 0 4px; font-weight:600; color:var(--db-text);">{{ order.shipping_address.name }}</p>
                {% if order.shipping_address.company != blank %}<p style="margin:0 0 4px;">{{ order.shipping_address.company }}</p>{% endif %}
                <p style="margin:0 0 4px;">{{ order.shipping_address.street }}</p>
                <p style="margin:0 0 4px;">{{ order.shipping_address.city }}, {{ order.shipping_address.province }}</p>
                <p style="margin:0 0 4px;">{{ order.shipping_address.country }} {{ order.shipping_address.zip }}</p>
                {% if order.shipping_address.phone != blank %}<p style="margin:0;">{{ order.shipping_address.phone }}</p>{% endif %}
              </div>
            </div>
            {% endif %}
          </div>

          <div class="order-details-wrapper" style="overflow-x: auto;">
            <table class="db-mini-table" id="order_details">
              <thead>
                <tr>
                  <th>{{ 'customer.order.product' | t }}</th>
                  <th>{{ 'customer.order.sku' | t }}</th>
                  <th class="align-right" style="text-align: right;">{{ 'customer.order.price' | t }}</th>
                  <th class="align-center" style="text-align: center;">{{ 'customer.order.quantity' | t }}</th>
                  <th class="align-right" style="text-align: right;">{{ 'customer.order.total' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {% for line_item in order.line_items %}
                <tr id="{{ line_item.id }}">
                  <td class="product" style="padding: 12px 14px;">
                    <a href="{{ line_item.product.url }}" style="color:var(--db-text); text-decoration:none; font-weight:600; transition:color 0.2s;">{{ line_item.title }}</a>

                    {% if line_item.selling_plan_allocation.selling_plan %}
                      <p style="margin:4px 0 0; font-size:11px; color:var(--db-text-muted);">{{ line_item.selling_plan_allocation.selling_plan.name }}</p>
                    {% endif %}

                    {% if line_item.fulfillment %}
                      <div class="note" style="margin-top:6px; font-size:11px; color:var(--db-accent);">
                        {% assign date = line_item.fulfillment.created_at | date: format: "month_date_year" %}
                        {{ 'customer.order.fulfilled_on' | t: date: date }}
                        {% if line_item.fulfillment.tracking_number %}
                        <a href="{{ line_item.fulfillment.tracking_url }}" style="color:var(--db-accent); font-weight:700; text-decoration:underline;">{{ line_item.fulfillment.tracking_company }} #{{ line_item.fulfillment.tracking_number}}</a>
                        {% endif %}
                      </div>
                    {% endif %}

                    {% render 'line-item-properties', line_item: line_item %}
                  </td>
                  <td class="sku align-center note" style="text-align: center; font-size:12px; color:var(--db-text-muted);">{{ line_item.sku }}</td>
                  <td class="align-right" style="text-align: right;">
                    {% if line_item.original_line_price > line_item.final_line_price %}
                      <div class="original-price" style="text-decoration: line-through; color: var(--db-text-muted); font-size:11px;">{%- render "price", price: line_item.original_price, disable_currency_code: true -%}</div>
                      <div style="font-weight:600; color:var(--db-text);">{%- render "price", price: line_item.final_price, disable_currency_code: true -%}</div>
                    {% else %}
                      <div style="font-weight:600; color:var(--db-text);">{%- render "price", price: line_item.final_price, disable_currency_code: true -%}</div>
                    {% endif %}

                    {% render 'unit-price', variant: line_item %}

                    {% if line_item.line_level_discount_allocations.size > 0 %}
                      <ul class="cart-discount-list" style="list-style:none; padding:0; margin:4px 0 0; font-size:11px; color:var(--db-success);">
                      {% for discount_allocation in line_item.line_level_discount_allocations %}
                        <li class="cart-discount">
                          <span>{{ discount_allocation.discount_application.title }} (-{%- render "price", price: discount_allocation.amount, disable_currency_code: true -%})</span>
                        </li>
                      {% endfor %}
                      </ul>
                    {% endif %}
                  </td>
                  <td class="quantity align-center" style="text-align: center; font-weight:600;">{{ line_item.quantity }}</td>
                  <td class="align-right" style="text-align: right; font-weight:600; color:var(--db-text);">
                    {% if line_item.original_line_price != line_item.final_line_price %}
                      <div class="original-price" style="text-decoration: line-through; color: var(--db-text-muted); font-size:11px;">{%- render "price", price: line_item.original_line_price, disable_currency_code: true -%}</div>
                      <div>{%- render "price", price: line_item.final_line_price, disable_currency_code: true -%}</div>
                    {% else %}
                      <div>{%- render "price", price: line_item.final_line_price, disable_currency_code: true -%}</div>
                    {% endif %}
                  </td>
                </tr>
                {% endfor %}
              </tbody>
              <tfoot>
                <tr class="order_summary note">
                  <td class="label" colspan="4" style="text-align: right; padding: 10px 14px; font-size:12px; color:var(--db-text-muted);">{{ 'customer.order.subtotal' | t }}:</td>
                  <td class="align-right" style="text-align: right; padding: 10px 14px; font-weight:600; color:var(--db-text);">{%- render "price", price: order.line_items_subtotal_price, disable_currency_code: true -%}</td>
                </tr>

                {%- if order.cart_level_discount_applications != blank -%}
                  {%- for discount_application in order.cart_level_discount_applications -%}
                    <tr class="cart-discount" style="color: var(--db-success);">
                      <td class="cart-discount__label" colspan="4" style="text-align: right; padding: 10px 14px; font-size:12px;">{{ discount_application.title }}:</td>
                      <td class="cart-discount__amount align-right" style="text-align: right; padding: 10px 14px; font-weight:600;">-{%- render "price", price: discount_application.total_allocated_amount, disable_currency_code: true -%}</td>
                    </tr>
                  {%- endfor -%}
                {%- endif -%}

                {% for shipping_method in order.shipping_methods %}
                <tr class="order_summary note">
                  <td class="label" colspan="4" style="text-align: right; padding: 10px 14px; font-size:12px; color:var(--db-text-muted);">{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }}):</td>
                  <td class="align-right" style="text-align: right; padding: 10px 14px; font-weight:600; color:var(--db-text);">{%- render "price", price: shipping_method.price, disable_currency_code: true -%}</td>
                </tr>
                {% endfor %}

                {% for tax_line in order.tax_lines %}
                <tr class="order_summary note">
                  <td class="label" colspan="4" style="text-align: right; padding: 10px 14px; font-size:12px; color:var(--db-text-muted);">{{ 'customer.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate | times: 100 }}%):</td>
                  <td class="align-right" style="text-align: right; padding: 10px 14px; font-weight:600; color:var(--db-text);">{%- render "price", price: tax_line.price, disable_currency_code: true -%}</td>
                </tr>
                {% endfor %}

                <tr class="order_summary order_total" style="background: rgba(255,255,255,0.02); border-top: 1px solid var(--db-border);">
                  <td class="label" colspan="4" style="text-align: right; padding: 14px 14px; font-size:13px; font-weight:700; color:var(--db-accent); text-transform:uppercase; letter-spacing:1px;">{{ 'customer.order.total' | t }}:</td>
                  <td class="align-right cc-currency-convert" style="text-align: right; padding: 14px 14px; font-size:16px; font-weight:800; color:var(--db-accent);">{%- render "price", price: order.total_price, is_total_price: true -%}</td>
                </tr>
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
document.addEventListener("DOMContentLoaded", function(event) {
  // Mobile sidebar menu toggle
  var menuToggle = document.getElementById('dbMenuToggle');
  var sidebar = document.getElementById('dbSidebar');
  var overlay = document.getElementById('sidebarOverlay');
  
  if (menuToggle && sidebar && overlay) {
    menuToggle.addEventListener('click', function() {
      sidebar.classList.toggle('is-open');
      overlay.classList.toggle('is-open');
    });
    
    overlay.addEventListener('click', function() {
      sidebar.classList.remove('is-open');
      overlay.classList.remove('is-open');
    });
  }
});
</script>
