{% liquid
  assign history_dom_id = 'CardFlipHistory-' | append: section.id
  assign api_base_url = section.settings.api_base_url | strip
  assign campaign_id = section.settings.campaign_id | default: 'card-flip-2026' | strip
  assign history_limit = section.settings.history_limit | default: 0 | plus: 0
  assign max_customers = section.settings.max_customers | default: 1000 | plus: 0
  assign current_customer_id = ''
  if customer
    assign current_customer_id = customer.id
  endif
  assign scan_customers = section.settings.scan_customers
%}

<section
  id="{{ history_dom_id }}"
  class="card-flip-history"
  data-card-flip-history
  data-api-base="{{ api_base_url | escape }}"
  data-campaign-id="{{ campaign_id | escape }}"
  data-history-limit="{{ history_limit }}"
  data-max-customers="{{ max_customers }}"
  data-current-customer-id="{{ current_customer_id }}"
  data-scan-customers="{{ scan_customers }}"
  style="
    --cfh-bg: {{ section.settings.background_color }};
    --cfh-surface: {{ section.settings.surface_color }};
    --cfh-border: {{ section.settings.border_color }};
    --cfh-text: {{ section.settings.text_color }};
    --cfh-muted: {{ section.settings.muted_text_color }};
    --cfh-accent: {{ section.settings.accent_color }};
  "
>
  <div class="card-flip-history__wrap">
    <header class="card-flip-history__header">
      {% if section.settings.heading != blank %}
        <h2 class="card-flip-history__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <div class="card-flip-history__copy">{{ section.settings.subheading }}</div>
      {% endif %}
    </header>

    <form class="card-flip-history__controls" data-history-form>
      <label class="card-flip-history__field">
        <span>Campaign ID</span>
        <input type="text" name="campaign_id" value="{{ campaign_id | escape }}" autocomplete="off" required>
      </label>

      <label class="card-flip-history__field card-flip-history__field--search">
        <span>Tìm kiếm</span>
        <input type="search" name="search" autocomplete="off" placeholder="Email, customer ID, kết quả, mã...">
      </label>

      <button class="card-flip-history__button" type="submit">{{ section.settings.load_button_text }}</button>
      <button class="card-flip-history__button card-flip-history__button--secondary" type="button" data-export-csv disabled>{{ section.settings.export_button_text }}</button>
      <button class="card-flip-history__button card-flip-history__button--danger" type="button" data-delete-history>{{ section.settings.delete_button_text }}</button>
    </form>

    <div class="card-flip-history__status" data-history-status role="status" aria-live="polite"></div>

    <div class="card-flip-history__stats" data-history-stats hidden>
      <div class="card-flip-history__stat">
        <span>Tổng lượt mở</span>
        <strong data-stat-total>0</strong>
      </div>
      <div class="card-flip-history__stat">
        <span>Khách tham gia</span>
        <strong data-stat-customers>0</strong>
      </div>
      <div class="card-flip-history__stat">
        <span>Đang hiển thị</span>
        <strong data-stat-visible>0</strong>
      </div>
      <div class="card-flip-history__stat">
        <span>Tối đa hiển thị</span>
        <strong data-stat-limit>0</strong>
      </div>
    </div>

    <div class="card-flip-history__table-wrap" data-history-table-wrap hidden>
      <table class="card-flip-history__table">
        <thead>
          <tr>
            <th>Thời gian</th>
            <th>Customer ID</th>
            <th>Email</th>
            <th>Kết quả</th>
            <th>Mã</th>
            <th>Vị trí</th>
            <th>Ảnh</th>
          </tr>
        </thead>
        <tbody data-history-table></tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .card-flip-history {
    background: var(--cfh-bg);
    color: var(--cfh-text);
    padding: clamp(28px, 4vw, 56px) 16px;
  }

  .card-flip-history__wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    margin: 0 auto;
    max-width: 1240px;
    width: 100%;
  }

  .card-flip-history__wrap > * {
    min-width: 0;
    width: 100%;
  }

  .card-flip-history__header {
    display: grid;
    gap: 8px;
    margin-bottom: 24px;
    text-align: left;
  }

  .card-flip-history__title {
    color: var(--cfh-text);
    font-size: clamp(26px, 3vw, 38px);
    line-height: 1.15;
    margin: 0;
    text-align: left;
  }

  .card-flip-history__copy {
    color: var(--cfh-muted);
    line-height: 1.55;
  }

  .card-flip-history__controls {
    align-items: end;
    background: var(--cfh-surface);
    border: 1px solid var(--cfh-border);
    border-radius: 8px;
    box-sizing: border-box;
    clear: both;
    display: grid !important;
    float: none !important;
    gap: 12px;
    grid-template-columns: 1fr;
    max-width: none !important;
    margin-bottom: 16px;
    padding: 14px;
    width: 100% !important;
  }

  .card-flip-history__field {
    box-sizing: border-box;
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .card-flip-history__field span {
    color: var(--cfh-muted);
    font-size: 13px;
    line-height: 1.2;
  }

  .card-flip-history__field input {
    background: var(--cfh-surface);
    border: 1px solid var(--cfh-border);
    border-radius: 6px;
    box-sizing: border-box;
    color: var(--cfh-text);
    display: block !important;
    font: inherit;
    letter-spacing: 0;
    margin: 0 !important;
    max-width: none !important;
    min-height: 44px;
    min-width: 0;
    padding: 10px 12px;
    text-transform: none;
    width: 100%;
  }

  .card-flip-history__button {
    align-items: center;
    background: var(--cfh-accent);
    border: 1px solid var(--cfh-accent);
    border-radius: 6px;
    box-sizing: border-box;
    color: #111;
    cursor: pointer;
    display: inline-flex !important;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0;
    line-height: 1.2;
    margin: 0 !important;
    min-height: 44px;
    min-width: 116px;
    padding: 10px 16px;
    text-align: center;
    text-transform: none;
    white-space: nowrap;
    width: 100%;
  }

  .card-flip-history__button--secondary {
    background: transparent;
    color: var(--cfh-text);
  }

  .card-flip-history__button--danger {
    background: #b42318;
    border-color: #b42318;
    color: #fff;
  }

  .card-flip-history__button:disabled {
    cursor: default;
    opacity: 0.48;
  }

  .card-flip-history__status {
    color: var(--cfh-muted);
    min-height: 22px;
    margin: 10px 0 16px;
  }

  .card-flip-history__stats {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 16px;
  }

  .card-flip-history__stat {
    background: var(--cfh-surface);
    border: 1px solid var(--cfh-border);
    border-radius: 8px;
    display: grid;
    gap: 6px;
    min-height: 82px;
    padding: 14px;
  }

  .card-flip-history__stat span {
    color: var(--cfh-muted);
    font-size: 13px;
  }

  .card-flip-history__stat strong {
    color: var(--cfh-accent);
    font-size: 22px;
    line-height: 1.1;
    overflow-wrap: anywhere;
  }

  .card-flip-history__table-wrap {
    background: var(--cfh-surface);
    border: 1px solid var(--cfh-border);
    border-radius: 8px;
    overflow-x: auto;
  }

  .card-flip-history__table {
    border-collapse: collapse;
    min-width: 980px;
    width: 100%;
  }

  .card-flip-history__table th,
  .card-flip-history__table td {
    border-bottom: 1px solid var(--cfh-border);
    padding: 12px;
    text-align: left;
    vertical-align: middle;
  }

  .card-flip-history__table th {
    color: var(--cfh-muted);
    font-size: 13px;
    font-weight: 700;
  }

  .card-flip-history__table tr:last-child td {
    border-bottom: 0;
  }

  .card-flip-history__thumb {
    aspect-ratio: 3 / 4;
    background: #222;
    border-radius: 4px;
    display: block;
    height: 62px;
    object-fit: cover;
    width: 46px;
  }

  .card-flip-history__empty {
    color: var(--cfh-muted);
    padding: 18px;
    text-align: center;
  }

  @media (min-width: 960px) {
    .card-flip-history__controls {
      grid-template-columns: minmax(180px, 260px) minmax(320px, 1fr) 120px 120px 120px;
    }

    .card-flip-history__button {
      width: 120px;
    }
  }

  @media (max-width: 720px) {
    .card-flip-history__stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function () {
    const root = document.getElementById({{ history_dom_id | json }});
    if (!root || root.dataset.historyInitialized === 'true') return;
    root.dataset.historyInitialized = 'true';

    const form = root.querySelector('[data-history-form]');
    const status = root.querySelector('[data-history-status]');
    const stats = root.querySelector('[data-history-stats]');
    const tableWrap = root.querySelector('[data-history-table-wrap]');
    const tableBody = root.querySelector('[data-history-table]');
    const exportButton = root.querySelector('[data-export-csv]');
    const deleteButton = root.querySelector('[data-delete-history]');
    const searchInput = form.querySelector('[name="search"]');

    const config = {
      apiBase: normalizeApiBase(root.dataset.apiBase || ''),
      defaultCampaignId: root.dataset.campaignId || 'card-flip-2026',
      limit: toInt(root.dataset.historyLimit, 0),
      maxCustomers: toInt(root.dataset.maxCustomers, 1000),
      currentCustomerId: root.dataset.currentCustomerId || '',
      scanCustomers: root.dataset.scanCustomers === 'true',
      loadingText: {{ section.settings.loading_text | json }},
      emptyText: {{ section.settings.empty_text | json }},
      errorText: {{ section.settings.error_text | json }},
      deletePromptText: {{ section.settings.delete_prompt_text | json }},
      deleteConfirmText: {{ section.settings.delete_confirm_text | json }},
      deleteLoadingText: {{ section.settings.delete_loading_text | json }},
      deleteSuccessText: {{ section.settings.delete_success_text | json }},
      deletePasswordRequiredText: {{ section.settings.delete_password_required_text | json }}
    };

    let currentRows = [];
    let visibleRows = [];
    let lastSummary = null;

    form.addEventListener('submit', function (event) {
      event.preventDefault();
      loadHistory();
    });

    searchInput.addEventListener('input', renderTable);
    exportButton.addEventListener('click', exportCsv);
    deleteButton.addEventListener('click', deleteHistory);

    applyQueryParams();
    loadHistory();

    function applyQueryParams() {
      const params = new URLSearchParams(window.location.search);
      const campaignId = params.get('campaign_id');
      if (campaignId) {
        form.elements.campaign_id.value = campaignId;
      }
    }

    async function loadHistory() {
      const campaignId = form.elements.campaign_id.value.trim() || config.defaultCampaignId;

      if (!config.apiBase) {
        setStatus(config.errorText);
        return;
      }

      setStatus(config.loadingText);
      exportButton.disabled = true;
      tableBody.innerHTML = '';
      tableWrap.hidden = true;

      const params = new URLSearchParams({
        campaign_id: campaignId,
        max_customers: String(config.maxCustomers)
      });
      if (config.limit > 0) {
        params.set('limit', String(config.limit));
      } else {
        params.set('limit', 'all');
      }
      if (config.currentCustomerId) {
        params.set('include_customer_id', config.currentCustomerId);
      }
      if (config.scanCustomers) {
        params.set('scan_customers', 'true');
      }

      try {
        const response = await fetch(config.apiBase + '/card-flip/history?' + params.toString(), {
          method: 'GET',
          cache: 'no-store'
        });
        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.error || config.errorText);
        }

        currentRows = Array.isArray(data.history) ? data.history : [];
        lastSummary = data;
        renderTable();
        setStatus(getSummaryStatus(data));
      } catch (error) {
        currentRows = [];
        visibleRows = [];
        lastSummary = null;
        stats.hidden = true;
        tableWrap.hidden = true;
        setStatus(error.message || config.errorText);
      }
    }

    function updateStats() {
      stats.hidden = false;
      root.querySelector('[data-stat-total]').textContent = lastSummary ? lastSummary.total_entries || 0 : 0;
      root.querySelector('[data-stat-customers]').textContent = lastSummary ? lastSummary.unique_customers || 0 : 0;
      root.querySelector('[data-stat-visible]').textContent = visibleRows.length;
      root.querySelector('[data-stat-limit]').textContent = getDisplayLimit();
    }

    function renderTable() {
      const search = searchInput.value.trim().toLowerCase();
      visibleRows = currentRows.filter(function (row) {
        if (!search) return true;
        return [
          row.customer_id,
          row.customer_email,
          row.card_title,
          row.result_title,
          row.card_code,
          row.result_code,
          row.campaign_id,
          row.played_at
        ].some(function (value) {
          return String(value || '').toLowerCase().includes(search);
        });
      });

      tableBody.innerHTML = '';
      tableWrap.hidden = false;
      exportButton.disabled = visibleRows.length === 0;

      if (!visibleRows.length) {
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.colSpan = 7;
        cell.className = 'card-flip-history__empty';
        cell.textContent = config.emptyText;
        row.appendChild(cell);
        tableBody.appendChild(row);
        updateStats();
        return;
      }

      visibleRows.forEach(function (entry) {
        const row = document.createElement('tr');
        addCell(row, formatDate(entry.played_at));
        addCell(row, entry.customer_id || '-');
        addCell(row, entry.customer_email || '-');
        addCell(row, entry.result_title || entry.card_title || '-');
        addCell(row, entry.result_code || entry.card_code || '-');
        addCell(row, formatPosition(entry));
        addImageCell(row, entry.result_image || entry.card_image || '', entry.result_title || entry.card_title || '');
        tableBody.appendChild(row);
      });

      updateStats();
    }

    function addCell(row, value) {
      const cell = document.createElement('td');
      cell.textContent = value;
      row.appendChild(cell);
    }

    function addImageCell(row, src, alt) {
      const cell = document.createElement('td');
      if (src) {
        const image = document.createElement('img');
        image.className = 'card-flip-history__thumb';
        image.width = 46;
        image.height = 62;
        image.loading = 'lazy';
        image.src = src;
        image.alt = alt;
        cell.appendChild(image);
      } else {
        cell.textContent = '-';
      }
      row.appendChild(cell);
    }

    function exportCsv() {
      if (!visibleRows.length) return;

      const headers = ['played_at', 'customer_id', 'customer_email', 'campaign_id', 'card_title', 'card_code', 'card_position', 'deck_size'];
      const lines = [headers.join(',')].concat(visibleRows.map(function (row) {
        return headers.map(function (key) {
          return csvValue(row[key] || '');
        }).join(',');
      }));

      const blob = new Blob([lines.join('\n')], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      const campaignId = form.elements.campaign_id.value.trim() || 'campaign';
      link.href = url;
      link.download = 'card-flip-history-' + campaignId + '.csv';
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    async function deleteHistory() {
      const campaignId = form.elements.campaign_id.value.trim() || config.defaultCampaignId;
      if (!config.apiBase) {
        setStatus(config.errorText);
        return;
      }

      const password = window.prompt(config.deletePromptText);
      if (password === null) return;
      if (!password.trim()) {
        setStatus(config.deletePasswordRequiredText);
        return;
      }

      if (!window.confirm(config.deleteConfirmText.replace('[campaign]', campaignId))) {
        return;
      }

      setStatus(config.deleteLoadingText);
      deleteButton.disabled = true;
      exportButton.disabled = true;

      try {
        const response = await fetch(config.apiBase + '/card-flip/delete-history', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          cache: 'no-store',
          body: JSON.stringify({
            campaign_id: campaignId,
            password: password
          })
        });
        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.error || config.errorText);
        }

        searchInput.value = '';
        await loadHistory();
        setStatus(
          config.deleteSuccessText
            .replace('[count]', data.deleted_entries || 0)
            .replace('[customers]', data.updated_customers || 0)
        );
      } catch (error) {
        setStatus(error.message || config.errorText);
      } finally {
        deleteButton.disabled = false;
      }
    }

    function getSummaryStatus(data) {
      if (!currentRows.length) return config.emptyText;
      if (data.is_limited) {
        return 'Đang hiển thị ' + currentRows.length + ' / ' + data.total_entries + ' lượt.';
      }
      if (data.has_more_customers && data.scanned_customers) {
        return 'Đang hiển thị ' + currentRows.length + ' lượt gần nhất trong ' + data.scanned_customers + ' khách đã quét.';
      }
      return '';
    }

    function getDisplayLimit() {
      if (!lastSummary) return config.limit > 0 ? config.limit : 'Tất cả';
      if (lastSummary.limit === 'all' || lastSummary.limit === 0) return 'Tất cả';
      return lastSummary.limit || (config.limit > 0 ? config.limit : 'Tất cả');
    }

    function csvValue(value) {
      return '"' + String(value).replace(/"/g, '""') + '"';
    }

    function formatPosition(entry) {
      const position = entry.card_position || '-';
      const deckSize = entry.deck_size || '-';
      return position + '/' + deckSize;
    }

    function formatDate(value) {
      if (!value) return '-';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return date.toLocaleString('vi-VN', {
        hour12: false,
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      });
    }

    function setStatus(message) {
      status.textContent = message || '';
    }

    function toInt(value, fallback) {
      const number = parseInt(value, 10);
      return Number.isFinite(number) ? number : fallback;
    }

    function normalizeApiBase(value) {
      return String(value || '').replace(/\/+$/, '');
    }
  })();
</script>

{% schema %}
{
  "name": "Lịch sử lật thẻ",
  "tag": "section",
  "class": "section-card-flip-history",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề",
      "default": "Lịch sử lật thẻ"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Mô tả",
      "default": "Tất cả lượt mở theo campaign."
    },
    {
      "type": "text",
      "id": "api_base_url",
      "label": "API base URL",
      "default": "https://helios-tier-pricing-api-h543.vercel.app/api"
    },
    {
      "type": "text",
      "id": "campaign_id",
      "label": "Campaign ID mặc định",
      "default": "card-flip-2026"
    },
    {
      "type": "number",
      "id": "history_limit",
      "label": "Số lượt tối đa hiển thị (0 = tất cả)",
      "default": 0
    },
    {
      "type": "number",
      "id": "max_customers",
      "label": "Số customer tối đa khi backfill",
      "default": 1000
    },
    {
      "type": "checkbox",
      "id": "scan_customers",
      "label": "Quét thêm lịch sử cũ trong customer",
      "default": false
    },
    {
      "type": "text",
      "id": "load_button_text",
      "label": "Nút tải dữ liệu",
      "default": "Làm mới"
    },
    {
      "type": "text",
      "id": "export_button_text",
      "label": "Nút xuất CSV",
      "default": "Xuất CSV"
    },
    {
      "type": "text",
      "id": "delete_button_text",
      "label": "Nút xóa lịch sử",
      "default": "Xóa lịch sử"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Thông báo đang tải",
      "default": "Đang tải lịch sử..."
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Thông báo không có dữ liệu",
      "default": "Chưa có lượt mở cho campaign này."
    },
    {
      "type": "text",
      "id": "error_text",
      "label": "Thông báo lỗi",
      "default": "Không thể tải lịch sử."
    },
    {
      "type": "text",
      "id": "delete_prompt_text",
      "label": "Prompt nhập mật khẩu xóa",
      "default": "Nhập mật khẩu để xóa lịch sử"
    },
    {
      "type": "text",
      "id": "delete_confirm_text",
      "label": "Xác nhận xóa",
      "default": "Xóa toàn bộ lịch sử campaign [campaign]? Hành động này không thể hoàn tác."
    },
    {
      "type": "text",
      "id": "delete_loading_text",
      "label": "Thông báo đang xóa",
      "default": "Đang xóa lịch sử..."
    },
    {
      "type": "text",
      "id": "delete_success_text",
      "label": "Thông báo xóa thành công",
      "default": "Đã xóa [count] lượt trong [customers] khách."
    },
    {
      "type": "text",
      "id": "delete_password_required_text",
      "label": "Thông báo thiếu mật khẩu",
      "default": "Vui lòng nhập mật khẩu xóa lịch sử."
    },
    {
      "type": "header",
      "content": "Màu sắc"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Màu nền",
      "default": "#0f0f0f"
    },
    {
      "type": "color",
      "id": "surface_color",
      "label": "Màu khối",
      "default": "#181818"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Màu viền",
      "default": "#333333"
    },
    {
      "type": "color",
