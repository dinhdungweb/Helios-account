                    <td data-label="Mã đơn"><a href="{{ order.customer_url }}" class="order-link">{{ order.name }}</a></td>
                    <td data-label="Ngày đặt">{{ order.created_at | date: "%d/%m/%Y" }}</td>
                    <td data-label="Trạng thái"><span class="db-status-badge {{ order.financial_status_label | handle }}">{{ order.financial_status_label }}</span></td>
                    <td data-label="Tổng tiền" class="order-total">{{ order.total_price | money }}</td>
                  </tr>
                  {% endfor %}
