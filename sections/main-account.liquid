              {% for order in customer.orders limit: 5 %}
                <li class="db-points-item">
                  <div class="db-points-desc">Mua hàng {{ order.name }}</div>
                  <div class="db-points-right">
                    <div class="db-points-value">+{{ order.total_price | divided_by: 10000 | floor }} điểm</div>
                    <div class="db-points-date">{{ order.created_at | date: "%d/%m/%Y" }}</div>
                  </div>
                </li>
              {% endfor %}
              {% if customer.orders.size == 0 %}
                <li class="db-points-item">
                  <div class="db-points-desc db-empty">Chưa có lịch sử điểm</div>
                </li>
              {% endif %}
            </ul>
          </div>
        </div>
      </div>

      {% comment %}--- TIER IMAGE ---{% endcomment %}
      {% if section.settings.tier_image != blank %}
        <div class="db-card" style="margin-top: 20px; margin-bottom: 20px;">
          <div class="db-card-body" style="padding: 0;">
            <div class="db-tier-image">
              <img src="{{ section.settings.tier_image | image_url: width: 1400 }}" alt="Tier" loading="lazy" width="{{ section.settings.tier_image.width }}" height="{{ section.settings.tier_image.height }}" />
            </div>
          </div>
        </div>
      {% endif %}

      {% comment %}========== ROW 5: PRODUCTS =========={% endcomment %}
      {% if section.settings.welcome_collection != blank %}
        {% assign welcome_collection = collections[section.settings.welcome_collection] %}
        {% if welcome_collection != blank and welcome_collection.products.size > 0 %}
          <div class="db-products-row" id="section-products">
            <div class="db-card">
              <div class="db-card-header">
                <h3 class="db-card-title">{{ section.settings.welcome_collection_title | default: 'Sản Phẩm Đặc Quyền' }}</h3>
                <a class="db-card-action" href="{{ welcome_collection.url }}">Xem tất cả →</a>
              </div>
              <div class="db-card-body">
                <div class="db-products-grid">
                  {% assign products_limit = section.settings.welcome_products_limit | default: 4 %}
                  {% for product in welcome_collection.products limit: products_limit %}
                    <div class="db-product-item">
                      {% render 'product-block', product: product, show_vendor: false, animate: true, i: forloop.index %}
                    </div>
                  {% endfor %}
                </div>
                {% if welcome_collection.products.size > products_limit %}
                  <div class="db-products-more">
                    <a href="{{ welcome_collection.url }}" class="dashboard-btn outline">
                      Xem tất cả {{ welcome_collection.title }}
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endif %}

      {% comment %}========== ROW 5B: BLACKSUN CLUB BLOG =========={% endcomment %}
      {% if section.settings.blacksun_blog != blank %}
        {% assign bs_blog = blogs[section.settings.blacksun_blog] %}
        {% if bs_blog.articles.size > 0 %}
          <div class="db-card" id="section-blacksun" style="margin-top: 20px; margin-bottom: 20px;">
            <div class="db-card-header">
              <h3 class="db-card-title">{{ section.settings.blacksun_blog_title | default: 'Blacksun Club' }}</h3>
              <a class="db-card-action" href="{{ bs_blog.url }}">Xem tất cả →</a>
            </div>
            <div class="db-card-body">
              <div class="db-blog-grid">
                {% assign blog_limit = section.settings.blacksun_blog_limit | default: 4 %}
                {% for article in bs_blog.articles limit: blog_limit %}
                  <div class="db-blog-item">
                     <a href="{{ article.url }}" class="db-blog-link">
                       <div class="db-blog-image">
                         {% if article.image %}
                           <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title }}" loading="lazy">
                         {% endif %}
                       </div>
                       <h4 class="db-blog-title">{{ article.title }}</h4>
                     </a>
                  </div>
                {% endfor %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endif %}

      {% comment %}========== ROW 6: COMMUNITY =========={% endcomment %}
      <div class="db-card" id="section-community">
        <div class="db-card-header">
          <h3 class="db-card-title">Helios Community</h3>
        </div>
        <div class="db-card-body">
          <div class="db-community-layout">
            <div class="db-community-img">
              <img 
                src="https://cdn.shopify.com/s/files/1/0644/2958/8701/files/z6465765703069_030e64083cc975d6127ff8a441409631_95f8c0e0-1f78-4f16-b036-4de58aa1d26c.jpg?v=1743569814" 
                alt="Helios Community"
                width="1200"
                height="800"
                loading="lazy"
              />
            </div>
            <div class="db-community-text">
              <p>Helios Club là cộng đồng dành riêng cho những người 'khác biệt'– những anh em quan tâm đến thời trang, phụ kiện và đặc biệt là những ai đam mê 'màu' Helios.</p>
              <p>Đây là nơi để anh em chia sẻ trải nghiệm, kinh nghiệm sử dụng phụ kiện, những câu chuyện phía sau món đồ; đồng thời là không gian mở để đặt câu hỏi, tư vấn, trao đổi và thảo luận.</p>
              <p>Nếu bạn yêu thích sự khác biệt: Chào mừng bạn đến với Helios Club!</p>
              <a href="https://www.facebook.com/groups/508707569692422" target="_blank" class="dashboard-btn" style="margin-top:8px; align-self: flex-start;">
                Tham gia ngay
              </a>
            </div>
          </div>
        </div>
      </div>



      {% comment %}--- CUSTOM TAB CONTENT (from blocks) ---{% endcomment %}
      {% for block in section.blocks %}
        {% if block.type == 'custom_tab' %}
          {% unless block.settings.enable_link and block.settings.tab_url != blank %}
            <div class="db-card" id="custom-tab-{{ block.id }}" style="margin-top: 20px;">
              <div class="db-card-header">
                <h3 class="db-card-title">{{ block.settings.title }}</h3>
              </div>
              <div class="db-card-body">
                {% if block.settings.page_content != blank %}
                  {{ pages[block.settings.page_content].content }}
                {% else %}
                  <div class="rte">
                    {{ block.settings.richtext_content }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endunless %}
        {% endif %}
      {% endfor %}

    </div>
  </div>
</div>

{% comment %}--- JAVASCRIPT ---{% endcomment %}
<script>
(function() {
  // Sidebar toggle (mobile)
  const sidebar = document.getElementById('dbSidebar');
  const overlay = document.getElementById('sidebarOverlay');
  const menuToggle = document.getElementById('dbMenuToggle');

  function openSidebar() {
    if (sidebar) sidebar.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    if (sidebar) sidebar.classList.remove('is-open');
    if (overlay) overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  if (menuToggle) menuToggle.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);

  // Handle navigation
  function handleNavigation(e, element, isNav) {
    e.preventDefault();
    const targetId = element.getAttribute('data-scroll');

    // Update active state for sidebar nav
    if (isNav) {
      document.querySelectorAll('.db-nav-item').forEach(function(el) { el.classList.remove('active'); });
      element.classList.add('active');
    }

    const dbContent = document.querySelector('.db-content');

    if (targetId === 'section-orders') {
      dbContent.classList.add('show-orders-tab');
      dbContent.classList.remove('show-account-tab', 'show-benefits-tab');
    } else if (targetId === 'section-account') {
      dbContent.classList.add('show-account-tab');
      dbContent.classList.remove('show-orders-tab', 'show-benefits-tab');
    } else if (targetId === 'section-benefits') {
      dbContent.classList.add('show-benefits-tab');
      dbContent.classList.remove('show-orders-tab', 'show-account-tab');
    } else {
      dbContent.classList.remove('show-orders-tab', 'show-account-tab', 'show-benefits-tab');
      if (targetId === 'top') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        const target = document.getElementById(targetId);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    }

    if (isNav) closeSidebar();
  }

  // Sidebar nav
  document.querySelectorAll('.db-nav-item[data-scroll]').forEach(function(item) {
    item.addEventListener('click', function(e) { handleNavigation(e, this, true); });
  });


  // Check hash on load
  if (window.location.hash === '#section-orders') {
    const ordersNav = document.querySelector('.db-nav-item[data-scroll="section-orders"]');
    if (ordersNav) {
      document.querySelectorAll('.db-nav-item').forEach(function(el) { el.classList.remove('active'); });
      ordersNav.classList.add('active');
    }
    document.querySelector('.db-content').classList.add('show-orders-tab');
  } else if (window.location.hash === '#section-account') {
    const accountNav = document.querySelector('.db-nav-item[data-scroll="section-account"]');
    if (accountNav) {
      document.querySelectorAll('.db-nav-item').forEach(function(el) { el.classList.remove('active'); });
      accountNav.classList.add('active');
    }
    document.querySelector('.db-content').classList.add('show-account-tab');
  }
})();
</script>

