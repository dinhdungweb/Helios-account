                <div class="db-tier-points-value">{{ fmt_pts }} <span class="db-tier-points-unit">điểm</span></div>
              </div>
            </div>

            <p class="db-tier-progress-msg">
              {% if next_tier == "MAX LEVEL" %}
                Bạn đã đạt hạng cao nhất!
              {% else %}
                Chi tiêu thêm <strong>{{ fmt_rem }}đ</strong> để lên hạng <strong>{{ next_tier }}</strong>
              {% endif %}
