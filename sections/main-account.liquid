            <div class="db-tier-progress-bar">
              <div class="db-tier-progress-fill" style="width: {{ progress_percentage }}%;"></div>
            </div>
            <div class="db-tier-progress-text">
              <span>{{ fmt_ts }}</span>
              <span>{% if next_tier != "MAX LEVEL" %}{{ next_tier_amount | divided_by: 1000000 }}M{% else %}MAX{% endif %}</span>
