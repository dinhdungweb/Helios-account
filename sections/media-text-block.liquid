{%- comment -%}
  Section: Media Text Block
  - Media: Video (Shopify hosted / URL) hoặc Image
  - Text: Heading, Description (richtext), Button
  - Đổi bên media/text
  - Background image
  - Responsive: Desktop/Mobile media riêng
  - Lazy load video qua IntersectionObserver
  - Tối ưu hiệu suất: srcset, sizes, contain-intrinsic-size, will-change
{%- endcomment -%}

{%- liquid
  assign section_id = 'mtb-' | append: section.id
  assign layout_reverse = false
  if section.settings.media_position == 'right'
    assign layout_reverse = true
  endif
-%}

{% style %}
  #{{ section_id }} {
    --mtb-heading-size: {{ section.settings.heading_size }}px;
    --mtb-heading-size-mb: {{ section.settings.heading_size | times: 0.7 | round }}px;
    --mtb-text-color: {{ section.settings.text_color }};
    --mtb-heading-color: {{ section.settings.heading_color }};
    --mtb-btn-bg: {{ section.settings.button_bg }};
    --mtb-btn-color: {{ section.settings.button_text_color }};
    --mtb-btn-bg-hover: {{ section.settings.button_bg_hover }};
    --mtb-btn-color-hover: {{ section.settings.button_text_color_hover }};
    --mtb-overlay-color: {{ section.settings.overlay_color }};
    --mtb-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --mtb-content-padding: {{ section.settings.content_padding }}px;
    --mtb-media-ratio: {{ section.settings.media_ratio }};
    --mtb-section-height: {{ section.settings.section_height }};
  }
{% endstyle %}

<section id="{{ section_id }}" class="mtb-section" aria-label="{{ section.settings.heading | escape }}">
  {%- comment -%} Background image {%- endcomment -%}
  {%- if section.settings.bg_image != blank -%}
    <div class="mtb-bg" aria-hidden="true">
      <img
        src="{{ section.settings.bg_image | image_url: width: 50 }}"
        srcset="{%- if section.settings.bg_image.width >= 750 -%}{{ section.settings.bg_image | image_url: width: 750 }} 750w,{%- endif -%}
               {%- if section.settings.bg_image.width >= 1100 -%}{{ section.settings.bg_image | image_url: width: 1100 }} 1100w,{%- endif -%}
               {%- if section.settings.bg_image.width >= 1500 -%}{{ section.settings.bg_image | image_url: width: 1500 }} 1500w,{%- endif -%}
               {%- if section.settings.bg_image.width >= 1920 -%}{{ section.settings.bg_image | image_url: width: 1920 }} 1920w,{%- endif -%}
               {{ section.settings.bg_image | image_url: width: section.settings.bg_image.width }} {{ section.settings.bg_image.width }}w"
        sizes="100vw"
        alt=""
        loading="lazy"
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
        class="mtb-bg__img"
      >
    </div>
    <div class="mtb-overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="mtb-container{% if layout_reverse %} mtb-container--reverse{% endif %}">
    {%- comment -%} ===== MEDIA COLUMN ===== {%- endcomment -%}
    <div class="mtb-media">
      {%- if section.settings.media_type == 'video' -%}
        {%- comment -%} === VIDEO === {%- endcomment -%}

        {%- comment -%} Desktop Video {%- endcomment -%}
        {%- if section.settings.video_shopify != blank -%}
          <div class="mtb-media__item mtb-media__item--desktop"
               data-mtb-lazy-video
               data-video-autoplay="true"
               data-video-loop="{{ section.settings.video_loop }}">
            {%- if section.settings.media_image != blank -%}
              <img
                src="{{ section.settings.media_image | image_url: width: 600 }}"
                srcset="{{ section.settings.media_image | image_url: width: 400 }} 400w,
                       {{ section.settings.media_image | image_url: width: 600 }} 600w,
                       {{ section.settings.media_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 769px) 50vw, 100vw"
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
                width="{{ section.settings.media_image.width }}"
                height="{{ section.settings.media_image.height }}"
                class="mtb-media__poster"
              >
            {%- endif -%}
            <div class="mtb-media__video-wrap">
              {%- for source in section.settings.video_shopify.sources -%}
                <template data-src="{{ source.url }}" data-type="{{ source.mime_type }}"></template>
              {%- endfor -%}
            </div>
          </div>
        {%- elsif section.settings.video_url != blank -%}
          <div class="mtb-media__item mtb-media__item--desktop"
               data-mtb-lazy-video
               data-video-autoplay="true"
               data-video-loop="{{ section.settings.video_loop }}"
               data-video-ext-url="{{ section.settings.video_url }}">
            {%- if section.settings.media_image != blank -%}
              <img
                src="{{ section.settings.media_image | image_url: width: 600 }}"
                srcset="{{ section.settings.media_image | image_url: width: 400 }} 400w,
                       {{ section.settings.media_image | image_url: width: 600 }} 600w,
                       {{ section.settings.media_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 769px) 50vw, 100vw"
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
                width="{{ section.settings.media_image.width }}"
                height="{{ section.settings.media_image.height }}"
                class="mtb-media__poster"
              >
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Mobile Video (fallback to desktop if not set) {%- endcomment -%}
        {%- if section.settings.video_shopify_mobile != blank -%}
          <div class="mtb-media__item mtb-media__item--mobile"
               data-mtb-lazy-video
               data-video-autoplay="true"
               data-video-loop="{{ section.settings.video_loop }}">
            {%- if section.settings.media_image_mobile != blank -%}
              <img
                src="{{ section.settings.media_image_mobile | image_url: width: 400 }}"
                srcset="{{ section.settings.media_image_mobile | image_url: width: 300 }} 300w,
                       {{ section.settings.media_image_mobile | image_url: width: 400 }} 400w,
                       {{ section.settings.media_image_mobile | image_url: width: 600 }} 600w"
                sizes="100vw"
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
                width="{{ section.settings.media_image_mobile.width }}"
                height="{{ section.settings.media_image_mobile.height }}"
                class="mtb-media__poster"
              >
            {%- elsif section.settings.media_image != blank -%}
              <img
                src="{{ section.settings.media_image | image_url: width: 400 }}"
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
                class="mtb-media__poster"
              >
            {%- endif -%}
            <div class="mtb-media__video-wrap">
              {%- for source in section.settings.video_shopify_mobile.sources -%}
                <template data-src="{{ source.url }}" data-type="{{ source.mime_type }}"></template>
              {%- endfor -%}
            </div>
          </div>
        {%- elsif section.settings.video_url_mobile != blank -%}
          <div class="mtb-media__item mtb-media__item--mobile"
               data-mtb-lazy-video
               data-video-autoplay="true"
               data-video-loop="{{ section.settings.video_loop }}"
               data-video-ext-url="{{ section.settings.video_url_mobile }}">
            {%- if section.settings.media_image_mobile != blank -%}
              <img
                src="{{ section.settings.media_image_mobile | image_url: width: 400 }}"
                alt="{{ section.settings.heading | escape }}"
                loading="lazy"
                class="mtb-media__poster"
              >
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- else -%}
        {%- comment -%} === IMAGE === {%- endcomment -%}

        {%- comment -%} Desktop Image {%- endcomment -%}
        {%- if section.settings.media_image != blank -%}
          <div class="mtb-media__item mtb-media__item--desktop">
            <img
              src="{{ section.settings.media_image | image_url: width: 800 }}"
              srcset="{%- if section.settings.media_image.width >= 400 -%}{{ section.settings.media_image | image_url: width: 400 }} 400w,{%- endif -%}
                     {%- if section.settings.media_image.width >= 600 -%}{{ section.settings.media_image | image_url: width: 600 }} 600w,{%- endif -%}
                     {%- if section.settings.media_image.width >= 800 -%}{{ section.settings.media_image | image_url: width: 800 }} 800w,{%- endif -%}
                     {%- if section.settings.media_image.width >= 1000 -%}{{ section.settings.media_image | image_url: width: 1000 }} 1000w,{%- endif -%}
                     {{ section.settings.media_image | image_url: width: section.settings.media_image.width }} {{ section.settings.media_image.width }}w"
              sizes="(min-width: 769px) 50vw, 100vw"
              alt="{{ section.settings.media_image.alt | default: section.settings.heading | escape }}"
              loading="lazy"
              width="{{ section.settings.media_image.width }}"
              height="{{ section.settings.media_image.height }}"
              class="mtb-media__img"
            >
          </div>
        {%- else -%}
          <div class="mtb-media__item mtb-media__item--desktop mtb-media__placeholder">
            {{ 'image' | placeholder_svg_tag: 'mtb-placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- comment -%} Mobile Image (nếu có) {%- endcomment -%}
        {%- if section.settings.media_image_mobile != blank -%}
          <div class="mtb-media__item mtb-media__item--mobile">
            <img
              src="{{ section.settings.media_image_mobile | image_url: width: 400 }}"
              srcset="{%- if section.settings.media_image_mobile.width >= 300 -%}{{ section.settings.media_image_mobile | image_url: width: 300 }} 300w,{%- endif -%}
                     {%- if section.settings.media_image_mobile.width >= 400 -%}{{ section.settings.media_image_mobile | image_url: width: 400 }} 400w,{%- endif -%}
                     {%- if section.settings.media_image_mobile.width >= 600 -%}{{ section.settings.media_image_mobile | image_url: width: 600 }} 600w,{%- endif -%}
                     {{ section.settings.media_image_mobile | image_url: width: section.settings.media_image_mobile.width }} {{ section.settings.media_image_mobile.width }}w"
              sizes="100vw"
              alt="{{ section.settings.media_image_mobile.alt | default: section.settings.heading | escape }}"
              loading="lazy"
              width="{{ section.settings.media_image_mobile.width }}"
              height="{{ section.settings.media_image_mobile.height }}"
              class="mtb-media__img"
            >
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- comment -%} ===== TEXT COLUMN ===== {%- endcomment -%}
    <div class="mtb-text align-{{ section.settings.text_alignment }}">
      <div class="mtb-text__inner">
        {%- if section.settings.subheading != blank -%}
          <p class="mtb-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_tag }} class="mtb-heading{% if section.settings.heading_alignment != 'inherit' %} mtb-heading--{{ section.settings.heading_alignment }}{% endif %}">
            {{ section.settings.heading }}
          </{{ section.settings.heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="mtb-description rte">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="mtb-btn-wrap">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="mtb-btn{% if section.settings.button_style == 'outline' %} mtb-btn--outline{% endif %}"
              {% if section.settings.button_open_new %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              {{ section.settings.button_label | escape }}
            </a>

            {%- if section.settings.button_label_2 != blank -%}
              <a
                href="{{ section.settings.button_link_2 | default: '#' }}"
                class="mtb-btn mtb-btn--secondary{% if section.settings.button_style_2 == 'outline' %} mtb-btn--outline{% endif %}"
                {% if section.settings.button_open_new_2 %}target="_blank" rel="noopener noreferrer"{% endif %}
              >
                {{ section.settings.button_label_2 | escape }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== BASE ===== */
  .mtb-section {
    position: relative;
    overflow: hidden;
    width: 100%;
    contain: layout style;
  }

  /* ===== BACKGROUND ===== */
  .mtb-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .mtb-bg__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mtb-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--mtb-overlay-color);
    opacity: var(--mtb-overlay-opacity);
    pointer-events: none;
  }

  /* ===== CONTAINER ===== */
  .mtb-container {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: stretch;
    width: 100%;
    min-height: var(--mtb-section-height, auto);
  }
  .mtb-container--reverse {
    flex-direction: row-reverse;
  }

  /* ===== MEDIA ===== */
  .mtb-media {
    flex: 1 1 50%;
    max-width: 50%;
    position: relative;
    overflow: hidden;
  }
  .mtb-media__item {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }
  .mtb-media__item--mobile {
    display: none;
  }
  .mtb-media__img,
  .mtb-media__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mtb-media__video-wrap {
    position: absolute;
    inset: 0;
  }
  .mtb-media__video-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* Poster fade-out khi video loaded */
  .mtb-media__item[data-mtb-loaded] .mtb-media__poster {
    opacity: 0;
    transition: opacity 0.4s ease;
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .mtb-media__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    min-height: 300px;
  }
  .mtb-placeholder-svg {
    max-width: 60%;
    height: auto;
    opacity: 0.3;
  }

  /* ===== TEXT ===== */
  .mtb-text {
    flex: 1 1 50%;
    max-width: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--mtb-content-padding, 40px);
    box-sizing: border-box;
  }
  .mtb-text__inner {
    max-width: 560px;
    width: 100%;
  }
  .mtb-text.align-left { text-align: left; }
  .mtb-text.align-left .mtb-btn-wrap { justify-content: flex-start; }
  .mtb-text.align-center { text-align: center; }
  .mtb-text.align-center .mtb-btn-wrap { justify-content: center; }
  .mtb-text.align-right { text-align: right; }
  .mtb-text.align-right .mtb-btn-wrap { justify-content: flex-end; }

  .mtb-subheading {
    font-size: 0.85em;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 8px;
    color: var(--mtb-heading-color);
    opacity: 0.7;
  }
  .mtb-heading {
    font-size: var(--mtb-heading-size, 32px);
    line-height: 1.2;
    margin: 0 0 16px;
    color: var(--mtb-heading-color);
    font-weight: 700;
  }
  .mtb-heading--left { text-align: left; }
  .mtb-heading--center { text-align: center; }
  .mtb-heading--right { text-align: right; }
  .mtb-description {
    font-size: 1em;
    line-height: 1.65;
    color: var(--mtb-text-color);
    margin: 0 0 24px;
  }
  .mtb-description:last-child {
    margin-bottom: 0;
  }

  /* ===== BUTTONS ===== */
  .mtb-btn-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 8px;
  }
  .mtb-btn {
    display: inline-block;
    padding: 12px 28px;
    font-size: 0.9em;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    background: var(--mtb-btn-bg);
    color: var(--mtb-btn-color);
    border: 2px solid var(--mtb-btn-bg);
    transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.2s ease;
    cursor: pointer;
    text-align: center;
    min-width: 140px;
  }
  .mtb-btn:hover {
    background: var(--mtb-btn-bg-hover);
    color: var(--mtb-btn-color-hover);
    border-color: var(--mtb-btn-bg-hover);
    transform: translateY(-1px);
  }
  .mtb-btn--outline {
    background: transparent;
    color: var(--mtb-btn-bg);
  }
  .mtb-btn--outline:hover {
    background: var(--mtb-btn-bg);
    color: var(--mtb-btn-color);
  }
  .mtb-btn--secondary {
    --mtb-btn-bg: transparent;
    --mtb-btn-color: var(--mtb-heading-color);
    border-color: var(--mtb-heading-color);
  }
  .mtb-btn--secondary:hover {
    --mtb-btn-bg: var(--mtb-heading-color);
    --mtb-btn-color: #fff;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .mtb-container,
    .mtb-container--reverse {
      flex-direction: column !important;
    }
    .mtb-media,
    .mtb-text {
      flex: 1 1 100%;
      max-width: 100%;
    }
    .mtb-media__item--desktop {
      display: none;
    }
    .mtb-media__item--mobile {
      display: block;
    }
    /* Nếu không có mobile media riêng, hiện lại desktop */
    .mtb-media__item--desktop:only-child {
      display: block;
    }
    .mtb-text {
      padding: 24px 16px;
    }
    .mtb-heading {
      font-size: var(--mtb-heading-size-mb, 24px);
    }
    .mtb-media__placeholder {
      min-height: 200px;
    }
  }
  @media (min-width: 769px) and (max-width: 1024px) {
    .mtb-text {
      padding: 24px;
    }
    .mtb-heading {
      font-size: calc(var(--mtb-heading-size, 32px) * 0.85);
    }
  }
</style>

<script>
  (function(){
    'use strict';
    /* Lazy load video qua IntersectionObserver — chỉ tạo <video> khi element gần viewport */
    if (!('IntersectionObserver' in window)) return;

    function loadVideo(container) {
      if (container.hasAttribute('data-mtb-loaded')) return;
      container.setAttribute('data-mtb-loaded', '');

      var autoplay = container.getAttribute('data-video-autoplay') === 'true';
      var loop = container.getAttribute('data-video-loop') === 'true';
      var extUrl = container.getAttribute('data-video-ext-url');
      var wrap = container.querySelector('.mtb-media__video-wrap');

      var video = document.createElement('video');
      video.muted = true;
      video.playsInline = true;
      video.loop = loop;
      video.preload = 'metadata';
      video.setAttribute('playsinline', '');
      video.setAttribute('muted', '');

      if (extUrl) {
        /* External MP4 URL */
        var src = document.createElement('source');
        src.src = extUrl;
        src.type = 'video/mp4';
        video.appendChild(src);
      } else if (wrap) {
        /* Shopify hosted — đọc từ <template> */
        var templates = wrap.querySelectorAll('template[data-src]');
        templates.forEach(function(t) {
          var src = document.createElement('source');
          src.src = t.getAttribute('data-src');
          src.type = t.getAttribute('data-type');
          video.appendChild(src);
        });
      }

      if (wrap) {
        wrap.innerHTML = '';
        wrap.appendChild(video);
      } else {
        /* ext url — tạo wrap */
        var w = document.createElement('div');
        w.className = 'mtb-media__video-wrap';
        w.appendChild(video);
        container.appendChild(w);
      }

      if (autoplay) {
        video.addEventListener('canplay', function() {
          var p = video.play();
          if (p && p.catch) p.catch(function(){});
        }, { once: true });
      }
      video.load();
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          /* delay nhẹ để không block main thread */
          if ('requestIdleCallback' in window) {
            requestIdleCallback(function(){ loadVideo(entry.target); }, { timeout: 500 });
          } else {
            setTimeout(function(){ loadVideo(entry.target); }, 200);
          }
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: '200px', threshold: 0.01 });

    function init() {
      var items = document.querySelectorAll('[data-mtb-lazy-video]');
      items.forEach(function(el){ observer.observe(el); });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    /* Shopify theme editor */
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:load', init);
    }
  })();
</script>

{% schema %}
{
  "name": "Media Text Block",
  "tag": "section",
  "class": "section-media-text-block",
  "settings": [
    {
      "type": "header",
      "content": "📝 Nội dung"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Media Text Block"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p", "label": "Paragraph" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Theo text alignment" },
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Mô tả nội dung ở đây. Hỗ trợ rich text.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Content padding",
      "default": 40
    },
    {
      "type": "header",
      "content": "🔘 Button 1"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
