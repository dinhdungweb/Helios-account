{% comment %}
  Announcement Countdown Bar - HELIOS Style
  Responsive, bulletproof layout & fully customizable via Theme Editor.
{% endcomment %}
{%- assign ac_id = section.id | replace: '_', '-' -%}

{%- if section.settings.show_section -%}
  {%- if section.settings.home_only == false or template == 'index' -%}

    {%- if section.settings.use_gothic_number -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Pirata+One&display=swap" rel="stylesheet">
    {%- endif -%}

    <style>
      .ac-bar-wrapper-{{ ac_id }} {
        --ac-bg: {{ section.settings.bg_color }};
        --ac-text: {{ section.settings.text_color }};
        --ac-num: {{ section.settings.number_color }};
        --ac-label: {{ section.settings.label_color }};
        --ac-num-font: {% if section.settings.custom_num_font != blank %}{{ section.settings.custom_num_font }}{% elsif section.settings.use_gothic_number %}'Cinzel Decorative', 'Pirata One', Georgia, serif{% else %}var(--heading-font-stack, inherit){% endif %};
        
        display: block !important;
        width: 100% !important;
        background-color: var(--ac-bg) !important;
        color: var(--ac-text) !important;
        padding-top: {{ section.settings.padding_top }}px !important;
        padding-bottom: {{ section.settings.padding_bottom }}px !important;
        border-bottom: {{ section.settings.border_bottom_width }}px solid {{ section.settings.border_bottom_color }} !important;
        position: relative !important;
        z-index: 100 !important;
        clear: both !important;
        box-sizing: border-box !important;
        overflow: hidden !important;
      }

      .ac-bar-wrapper-{{ ac_id }} * {
        box-sizing: border-box !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-container-{{ ac_id }} {
        display: flex !important;
        flex-direction: row !important;
        align-items: center !important;
        justify-content: {{ section.settings.text_align }} !important;
        flex-wrap: wrap !important;
        gap: 12px !important;
        width: 100% !important;
        max-width: {{ section.settings.max_width }}px !important;
        margin: 0 auto !important;
        padding: 0 24px !important;
      }

      /* Link wrapper if whole bar is clickable */
      .ac-bar-wrapper-{{ ac_id }} a.ac-link-wrap-{{ ac_id }} {
        display: flex !important;
        flex-direction: row !important;
        align-items: center !important;
        justify-content: {{ section.settings.text_align }} !important;
        flex-wrap: wrap !important;
        gap: 12px !important;
        width: 100% !important;
        text-decoration: none !important;
        color: inherit !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-prefix-{{ ac_id }} {
        display: inline-block !important;
        font-size: {{ section.settings.prefix_size }}px !important;
        font-weight: 700 !important;
        letter-spacing: 1.2px !important;
        text-transform: uppercase !important;
        color: var(--ac-text) !important;
        line-height: 1 !important;
        margin: 0 !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-separator-{{ ac_id }} {
        display: inline-block !important;
        font-size: {{ section.settings.prefix_size }}px !important;
        font-weight: 700 !important;
        color: var(--ac-text) !important;
        margin: 0 4px !important;
        line-height: 1 !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-countdown-{{ ac_id }} {
        display: inline-flex !important;
        flex-direction: row !important;
        align-items: baseline !important;
        flex-wrap: wrap !important;
        gap: 8px !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-unit-{{ ac_id }} {
        display: inline-flex !important;
        flex-direction: row !important;
        align-items: baseline !important;
        gap: 3px !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-num-{{ ac_id }} {
        font-family: var(--ac-num-font) !important;
        font-size: {{ section.settings.number_size }}px !important;
        font-weight: 900 !important;
        color: var(--ac-num) !important;
        line-height: 1 !important;
        letter-spacing: -0.5px !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-label-{{ ac_id }} {
        font-size: {{ section.settings.label_size }}px !important;
        font-weight: 700 !important;
        letter-spacing: 1px !important;
        text-transform: uppercase !important;
        color: var(--ac-label) !important;
        line-height: 1 !important;
      }

      .ac-bar-wrapper-{{ ac_id }} .ac-expired-msg-{{ ac_id }} {
        font-size: {{ section.settings.prefix_size }}px !important;
        font-weight: 700 !important;
        letter-spacing: 1.5px !important;
        text-transform: uppercase !important;
        color: var(--ac-num) !important;
      }

      /* Responsive for Mobile */
      @media screen and (max-width: 749px) {
        .ac-bar-wrapper-{{ ac_id }} {
          padding-top: {{ section.settings.padding_top | times: 0.8 }}px !important;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.8 }}px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-container-{{ ac_id }} {
          padding: 0 14px !important;
          gap: 6px !important;
          justify-content: center !important;
        }

        .ac-bar-wrapper-{{ ac_id }} a.ac-link-wrap-{{ ac_id }} {
          justify-content: center !important;
          gap: 6px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-prefix-{{ ac_id }} {
          font-size: {{ section.settings.prefix_size_mobile }}px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-separator-{{ ac_id }} {
          font-size: {{ section.settings.prefix_size_mobile }}px !important;
          margin: 0 2px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-num-{{ ac_id }} {
          font-size: {{ section.settings.number_size_mobile }}px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-label-{{ ac_id }} {
          font-size: {{ section.settings.label_size_mobile }}px !important;
        }

        .ac-bar-wrapper-{{ ac_id }} .ac-countdown-{{ ac_id }} {
          gap: 6px !important;
        }
      }
    </style>

    <div class="ac-bar-wrapper-{{ ac_id }}" data-section-id="{{ section.id }}">
      <div class="ac-container-{{ ac_id }}">
        {%- capture bar_inner_content -%}
          {%- if section.settings.prefix_text != blank -%}
            <span class="ac-prefix-{{ ac_id }}">{{ section.settings.prefix_text }}</span>
            <span class="ac-separator-{{ ac_id }}">{{ section.settings.separator }}</span>
          {%- endif -%}

          <div class="ac-countdown-{{ ac_id }}" id="ac-countdown-{{ ac_id }}" data-target-date="{{ section.settings.target_date }}">
            <span class="ac-unit-{{ ac_id }}">
              <span class="ac-num-{{ ac_id }}" id="ac-days-{{ ac_id }}">00</span>
              <span class="ac-label-{{ ac_id }}">{{ section.settings.label_days }}</span>
            </span>

            <span class="ac-unit-{{ ac_id }}">
              <span class="ac-num-{{ ac_id }}" id="ac-hours-{{ ac_id }}">00</span>
              <span class="ac-label-{{ ac_id }}">{{ section.settings.label_hours }}</span>
            </span>

            <span class="ac-unit-{{ ac_id }}">
              <span class="ac-num-{{ ac_id }}" id="ac-minutes-{{ ac_id }}">00</span>
              <span class="ac-label-{{ ac_id }}">{{ section.settings.label_minutes }}</span>
            </span>

            {%- if section.settings.show_seconds -%}
            <span class="ac-unit-{{ ac_id }}">
              <span class="ac-num-{{ ac_id }}" id="ac-seconds-{{ ac_id }}">00</span>
              <span class="ac-label-{{ ac_id }}">{{ section.settings.label_seconds }}</span>
            </span>
            {%- endif -%}
          </div>

          <div class="ac-expired-msg-{{ ac_id }}" id="ac-expired-{{ ac_id }}" style="display: none !important;">
            {{ section.settings.expired_text }}
          </div>
        {%- endcapture -%}

        {%- if section.settings.bar_link != blank -%}
          <a href="{{ section.settings.bar_link }}" class="ac-link-wrap-{{ ac_id }}">
            {{ bar_inner_content }}
          </a>
        {%- else -%}
          {{ bar_inner_content }}
        {%- endif -%}
      </div>
    </div>

    <script>
      (function() {
        var countdownElem = document.getElementById('ac-countdown-{{ ac_id }}');
        var expiredElem = document.getElementById('ac-expired-{{ ac_id }}');
        if (!countdownElem) return;

        var targetDateStr = countdownElem.getAttribute('data-target-date');
        var targetTime = new Date(targetDateStr).getTime();
        if (isNaN(targetTime)) {
          // If invalid date format, fallback to parsing ISO or YYYY/MM/DD
          targetTime = new Date(targetDateStr.replace(/-/g, '/')).getTime();
        }

        function updateCountdown() {
          var now = new Date().getTime();
          var distance = targetTime - now;

          if (isNaN(targetTime) || distance < 0) {
            countdownElem.style.setProperty('display', 'none', 'important');
            if (expiredElem && '{{ section.settings.expired_text }}' !== '') {
              expiredElem.style.setProperty('display', 'inline-block', 'important');
            }
            return;
          }

          var days = Math.floor(distance / (1000 * 60 * 60 * 24));
          var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          var seconds = Math.floor((distance % (1000 * 60)) / 1000);

          var daysEl = document.getElementById('ac-days-{{ ac_id }}');
          var hoursEl = document.getElementById('ac-hours-{{ ac_id }}');
          var minEl = document.getElementById('ac-minutes-{{ ac_id }}');
          var secEl = document.getElementById('ac-seconds-{{ ac_id }}');

          if (daysEl) daysEl.innerText = (days < 10 ? '0' : '') + days;
          if (hoursEl) hoursEl.innerText = (hours < 10 ? '0' : '') + hours;
          if (minEl) minEl.innerText = (minutes < 10 ? '0' : '') + minutes;
          if (secEl) secEl.innerText = (seconds < 10 ? '0' : '') + seconds;
        }

        updateCountdown();
        setInterval(updateCountdown, 1000);
      })();
    </script>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Thanh Announcement Count",
  "settings": [
    {
      "type": "header",
      "content": "Cài đặt chung"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Bật/Tắt thanh Announcement Countdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "home_only",
      "label": "Chỉ hiển thị tại Trang Chủ (Homepage Only)",
      "default": false
    },
    {
      "type": "url",
      "id": "bar_link",
      "label": "Đường dẫn khi nhấp vào thanh (Tùy chọn)"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Căn lề trên Desktop",
      "options": [
        { "value": "flex-start", "label": "Trái (Left)" },
        { "value": "center", "label": "Giữa (Center)" },
        { "value": "flex-end", "label": "Phải (Right - Như hình mẫu)" },
        { "value": "space-between", "label": "Hai đầu (Space Between)" }
      ],
      "default": "flex-end"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Chiều rộng tối đa (Max Width)",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "default": 1800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Khoảng cách trên (Padding Top)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Khoảng cách dưới (Padding Bottom)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Nội dung (Text & Date)"
    },
    {
      "type": "text",
      "id": "prefix_text",
      "label": "Tiêu đề trước đếm ngược",
      "default": "D-DAY 8/8/2026"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Dấu phân cách",
      "default": "·"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "Ngày giờ sự kiện (YYYY-MM-DDTHH:MM:SS)",
      "info": "Ví dụ: 2026-08-08T20:00:00",
      "default": "2026-08-08T20:00:00"
    },
    {
      "type": "text",
      "id": "expired_text",
      "label": "Thông báo khi hết giờ",
      "default": "SỰ KIỆN ĐANG DIỄN RA - TRUY CẬP NGAY"
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Hiển thị Giây (Seconds)",
      "default": false
    },
    {
      "type": "header",
      "content": "Nhãn đơn vị (Labels)"
    },
    {
      "type": "text",
      "id": "label_days",
      "label": "Nhãn Ngày",
      "default": "NGÀY"
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Nhãn Giờ",
      "default": "GIỜ"
    },
    {
      "type": "text",
      "id": "label_minutes",
      "label": "Nhãn Phút",
      "default": "PHÚT"
    },
    {
      "type": "text",
      "id": "label_seconds",
      "label": "Nhãn Giây",
      "default": "GIÂY"
    },
    {
      "type": "header",
      "content": "Màu sắc (Colors)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền thanh (Background)",
      "default": "#be6834"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ tiêu đề (Prefix Text Color)",
      "default": "#18110b"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Màu các số đếm (Number Color)",
      "default": "#18110b"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Màu nhãn ngày/giờ (Label Color)",
      "default": "#18110b"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Độ dày viền dưới (Border Bottom Width)",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Màu viền dưới (Border Bottom Color)",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Typography (Cỡ chữ & Font)"
    },
    {
      "type": "checkbox",
      "id": "use_gothic_number",
      "label": "Dùng font Gothic/Ornamental cho Số đếm (Cinzel Decorative/Pirata)",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_num_font",
      "label": "Custom Font Family cho Số (tùy chọn)",
      "placeholder": "VD: 'Pirata One', serif"
    },
    {
      "type": "range",
      "id": "prefix_size",
      "label": "Cỡ chữ Tiêu đề (Desktop)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "prefix_size_mobile",
      "label": "Cỡ chữ Tiêu đề (Mobile)",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Cỡ chữ Số đếm (Desktop)",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "number_size_mobile",
      "label": "Cỡ chữ Số đếm (Mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Cỡ chữ Nhãn đơn vị (Desktop)",
      "min": 9,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "label": "Cỡ chữ Nhãn đơn vị (Mobile)",
      "min": 8,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 9
    }
  ],
  "presets": [
    {
      "name": "Thanh Announcement Countdown"
    }
  ]
}
{% endschema %}
