{% comment %}
  Announcement Countdown Bar Section - HELIOS Style
  Renders the countdown bar using snippet announcement-countdown.liquid
{% endcomment %}
{% render 'announcement-countdown', settings_obj: section.settings %}

{% schema %}
{
  "name": "Thanh Announcement Count",
  "settings": [
    {
      "type": "header",
      "content": "Cài đặt chung"
    },
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Bật/Tắt thanh Announcement Countdown",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "home_only",
      "label": "Chỉ hiển thị tại Trang Chủ (Homepage Only)",
      "default": false
    },
    {
      "type": "url",
      "id": "bar_link",
      "label": "Đường dẫn khi nhấp vào thanh (Tùy chọn)"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Căn lề trên Desktop",
      "options": [
        { "value": "flex-start", "label": "Trái (Left)" },
        { "value": "center", "label": "Giữa (Center)" },
        { "value": "flex-end", "label": "Phải (Right - Như hình mẫu)" },
        { "value": "space-between", "label": "Hai đầu (Space Between)" }
      ],
      "default": "flex-end"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Chiều rộng tối đa (Max Width)",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "default": 1800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Khoảng cách trên (Padding Top)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Khoảng cách dưới (Padding Bottom)",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Nội dung (Text & Date)"
    },
    {
      "type": "text",
      "id": "prefix_text",
      "label": "Tiêu đề trước đếm ngược",
      "default": "D-DAY 8/8/2026"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Dấu phân cách",
      "default": "·"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "Ngày giờ sự kiện (YYYY-MM-DDTHH:MM:SS)",
      "info": "Ví dụ: 2026-08-08T20:00:00",
      "default": "2026-08-08T20:00:00"
    },
    {
      "type": "text",
      "id": "expired_text",
      "label": "Thông báo khi hết giờ",
      "default": "SỰ KIỆN ĐANG DIỄN RA - TRUY CẬP NGAY"
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "Hiển thị Giây (Seconds)",
      "default": false
    },
    {
      "type": "header",
      "content": "Nhãn đơn vị (Labels)"
    },
    {
      "type": "text",
      "id": "label_days",
      "label": "Nhãn Ngày",
      "default": "NGÀY"
    },
    {
      "type": "text",
      "id": "label_hours",
      "label": "Nhãn Giờ",
      "default": "GIỜ"
    },
    {
      "type": "text",
      "id": "label_minutes",
      "label": "Nhãn Phút",
      "default": "PHÚT"
    },
    {
      "type": "text",
      "id": "label_seconds",
      "label": "Nhãn Giây",
      "default": "GIÂY"
    },
    {
      "type": "header",
      "content": "Màu sắc (Colors)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền thanh (Background)",
      "default": "#be6834"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ tiêu đề (Prefix Text Color)",
      "default": "#18110b"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Màu các số đếm (Number Color)",
      "default": "#18110b"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Màu nhãn ngày/giờ (Label Color)",
      "default": "#18110b"
    },
    {
      "type": "range",
      "id": "border_bottom_width",
      "label": "Độ dày viền dưới (Border Bottom Width)",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Màu viền dưới (Border Bottom Color)",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Typography (Cỡ chữ & Font)"
    },
    {
      "type": "checkbox",
      "id": "use_gothic_number",
      "label": "Dùng font Gothic/Ornamental cho Số đếm (Cinzel Decorative/Pirata)",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_num_font",
      "label": "Custom Font Family cho Số (tùy chọn)",
      "placeholder": "VD: 'Pirata One', serif"
    },
    {
      "type": "range",
      "id": "prefix_size",
      "label": "Cỡ chữ Tiêu đề (Desktop)",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "prefix_size_mobile",
      "label": "Cỡ chữ Tiêu đề (Mobile)",
      "min": 9,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Cỡ chữ Số đếm (Desktop)",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "number_size_mobile",
      "label": "Cỡ chữ Số đếm (Mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Cỡ chữ Nhãn đơn vị (Desktop)",
      "min": 9,
      "max": 16,
      "step": 1,
      "unit": "px",
      "default": 11
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "label": "Cỡ chữ Nhãn đơn vị (Mobile)",
      "min": 8,
      "max": 14,
      "step": 1,
      "unit": "px",
      "default": 9
    }
  ],
  "presets": [
    {
      "name": "Thanh Announcement Countdown"
    }
  ]
}
{% endschema %}
