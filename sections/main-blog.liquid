{%- liquid
  assign show_blog_filters = false
  if blog.all_tags.size > 0 and section.settings.blog_show_filter
    assign show_blog_filters = true
  endif
-%}

<div class="helios-blog-wrapper" data-section-id="{{ section.id }}">
  
  <header class="blog-page-header">
    <h1 class="blog-page-header__title">{{ blog.title }}</h1>
    <nav class="blog-page-header__nav">
      {%- liquid
        assign nav_handles = 'tin-tuc,nhan,day-chuyen,vong-tay,bac,da,kinh' | split: ','
      -%}
      {% for handle in nav_handles %}
        <a
          href="{{ blogs[handle].url }}"
          class="blog-page-header__link {% if blog.handle == handle %}is-active{% endif %}"
        >
          {{ blogs[handle].title }}
        </a>
      {% endfor %}
    </nav>
  </header>

  {% paginate blog.articles by section.settings.blog_posts_per_page %}
    <div class="helios-banner-stack">
      {% for article in blog.articles %}
        {% render 'blog-card', article: article %}

        {%- comment -%} Check for in-feed blocks after this article {%- endcomment -%}
        {% for block in section.blocks %}
          {% if block.settings.insert_after == forloop.index %}
            <div class="helios-blog-banner in-feed-banner" {{ block.shopify_attributes }}>
              {% if block.type == 'banner_image' %}
                {% if block.settings.image != blank %}
                  <div class="banner__image-container" style="position: absolute; top:0; left:0; width:100%; height:100%;">
                    <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.title }}" class="banner__image" style="width:100%; height:100%; object-fit:cover;">
                  </div>
                {% endif %}
              {% elsif block.type == 'banner_video' %}
                {% if block.settings.video_url != blank %}
                   <div class="banner__video-container" style="position: absolute; top:0; left:0; width:100%; height:100%;">
                     <video autoplay muted loop playsinline style="width:100%; height:100%; object-fit:cover;">
                        <source src="{{ block.settings.video_url }}" type="video/mp4">
                     </video>
                   </div>
                {% endif %}
              {% endif %}

              <div class="banner__content">
                {% if block.settings.sub_title != blank %}
                  <div class="banner__title--small">{{ block.settings.sub_title }}</div>
                {% endif %}
                {% if block.settings.title != blank %}
                  <div class="banner__highlight">{{ block.settings.title }}</div>
                {% endif %}
                {% if block.settings.link_text != blank %}
                   <a href="{{ block.settings.link_url | default: '#' }}" class="banner__link">{{ block.settings.link_text }}</a>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}

      {% else %}
        <p class="align-centre" style="padding: 100px 0; opacity: 0.5;">
          <em>{{ 'blogs.general.no_matches' | t }}</em>
        </p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <div
        class="pagination-container"
        style="padding: 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.05);"
      >
        <div class="pagination central content">
          {% assign older_articles = 'blogs.pagination.older_articles' | t %}
          {% assign newer_articles = 'blogs.pagination.newer_articles' | t %}
          {{ paginate | default_pagination | replace: 'Previous', newer_articles | replace: 'Next', older_articles }}
        </div>
      </div>
    {% endif %}
  {% endpaginate %}

  <div class="banner-stack__footer" style="padding: 100px 0; text-align: center;">
    <p style="font-size: 11px; letter-spacing: 0.3em; opacity: 0.5;">END OF JOURNAL</p>
  </div>
</div>

{% render 'blog-styles-helper' %}

{% schema %}
{
  "name": "Blog pages",
  "settings": [
    {
      "type": "range",
      "id": "blog_posts_per_page",
      "label": "Posts per page",
      "min": 6,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "blog_show_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "blog_show_filter",
      "label": "Show tag filter",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "banner_image",
      "name": "In-feed Banner Image",
      "settings": [
        {
          "type": "number",
          "id": "insert_after",
          "label": "Insert after post number",
          "default": 3
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Sub Title",
          "default": "PROMOTION"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Main Title",
          "default": "Special Offer for Helios Members"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "DISCOVER NOW"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "banner_video",
      "name": "In-feed Banner Video",
      "settings": [
        {
          "type": "number",
          "id": "insert_after",
          "label": "Insert after post number",
          "default": 3
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "MP4 Video URL",
          "info": "Upload to Files and paste URL here"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Sub Title",
          "default": "STORY"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Main Title",
          "default": "The Art of Jewelry Making"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "WATCH STORY"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ]
}
{% endschema %}
