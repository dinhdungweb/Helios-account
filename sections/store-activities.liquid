{% comment %}
  Store Activities / Events Section - Responsive & Fully Customizable
  Created for HELIOS (4 Days - 4 Touch Activities)
{% endcomment %}

<section class="store-activities-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="sa-container">
    {%- if section.settings.subtitle != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <header class="sa-header sa-align-{{ section.settings.header_align }}">
        {%- if section.settings.subtitle != blank -%}
          <div class="sa-subtitle">{{ section.settings.subtitle }}</div>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="sa-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <div class="sa-description {% if section.settings.description_italic %}sa-desc-italic{% endif %}">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="sa-grid sa-mobile-{{ section.settings.mobile_layout }}">
      {%- for block in section.blocks -%}
        <div class="sa-card {% if section.settings.card_hover_effect %}sa-card--hover{% endif %}" {{ block.shopify_attributes }}
             {% if block.settings.custom_card_bg != blank or block.settings.custom_border_color != blank %}
               style="{% if block.settings.custom_card_bg != blank %}--sa-card-bg: {{ block.settings.custom_card_bg }};{% endif %} {% if block.settings.custom_border_color != blank %}--sa-card-border: {{ block.settings.custom_border_color }};{% endif %}"
             {% endif %}>
          
          <div class="sa-card__header">
            {%- if block.settings.date != blank -%}
              <div class="sa-card__date">{{ block.settings.date }}</div>
            {%- endif -%}
            
            {%- if block.settings.badge != blank -%}
              <div class="sa-card__badge">{{ block.settings.badge }}</div>
            {%- endif -%}
          </div>

          <div class="sa-card__body">
            {%- if block.settings.title != blank -%}
              <h3 class="sa-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.description != blank -%}
              <div class="sa-card__desc">{{ block.settings.description }}</div>
            {%- endif -%}
          </div>

          {%- if block.settings.link_label != blank -%}
            <div class="sa-card__footer">
              <a href="{{ block.settings.link_url | default: '#' }}" class="sa-card__link" {% if block.settings.link_url == blank %}aria-disabled="true"{% endif %}>
                <span>{{ block.settings.link_label }}</span>
                <span class="sa-card__link-arrow">→</span>
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if section.settings.import_gothic_font -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&display=swap" rel="stylesheet">
{%- endif -%}

<style>
  .store-activities-{{ section.id }} {
    --sa-bg: {{ section.settings.section_bg }};
    --sa-card-bg: {{ section.settings.card_bg }};
    --sa-card-border: {{ section.settings.card_border }};
    --sa-subtitle-color: {{ section.settings.subtitle_color }};
    --sa-heading-color: {{ section.settings.heading_color }};
    --sa-desc-color: {{ section.settings.description_color }};
    --sa-date-color: {{ section.settings.date_color }};
    --sa-badge-color: {{ section.settings.card_badge_color }};
    --sa-title-color: {{ section.settings.card_title_color }};
    --sa-card-desc-color: {{ section.settings.card_desc_color }};
    --sa-link-color: {{ section.settings.card_link_color }};
    --sa-link-hover-color: {{ section.settings.card_link_hover_color }};
    
    --sa-date-font: {% if section.settings.date_font_custom != blank %}{{ section.settings.date_font_custom }}{% elsif section.settings.import_gothic_font %}'Cinzel Decorative', 'Pirata One', Georgia, serif{% else %}inherit{% endif %};
    --sa-heading-font: {% if section.settings.heading_font_custom != blank %}{{ section.settings.heading_font_custom }}{% else %}var(--heading-font-stack, inherit){% endif %};

    background-color: var(--sa-bg);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .store-activities-{{ section.id }} .sa-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header Styles */
  .store-activities-{{ section.id }} .sa-header {
    margin-bottom: {{ section.settings.header_spacing }}px;
  }
  .store-activities-{{ section.id }} .sa-align-left { text-align: left; }
  .store-activities-{{ section.id }} .sa-align-center { text-align: center; }
  .store-activities-{{ section.id }} .sa-align-right { text-align: right; }

  .store-activities-{{ section.id }} .sa-subtitle {
    color: var(--sa-subtitle-color);
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: 600;
    letter-spacing: {{ section.settings.subtitle_letter_spacing }}px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .store-activities-{{ section.id }} .sa-heading {
    color: var(--sa-heading-color);
    font-family: var(--sa-heading-font);
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: 400;
    line-height: 1.25;
    margin: 0 0 16px 0;
  }

  .store-activities-{{ section.id }} .sa-description {
    color: var(--sa-desc-color);
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.6;
    margin: 0;
  }
  .store-activities-{{ section.id }} .sa-desc-italic {
    font-style: italic;
  }

  /* Grid & Cards */
  .store-activities-{{ section.id }} .sa-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.grid_columns_desktop }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
    align-items: stretch;
  }

  .store-activities-{{ section.id }} .sa-card {
    background-color: var(--sa-card-bg);
    border: 1px solid var(--sa-card-border);
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
    height: 100%;
  }

  .store-activities-{{ section.id }} .sa-card--hover:hover {
    border-color: var(--sa-link-color);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
  }

  .store-activities-{{ section.id }} .sa-card__header {
    margin-bottom: 24px;
  }

  .store-activities-{{ section.id }} .sa-card__date {
    color: var(--sa-date-color);
    font-family: var(--sa-date-font);
    font-size: {{ section.settings.date_size_desktop }}px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .store-activities-{{ section.id }} .sa-card__badge {
    color: var(--sa-badge-color);
    font-size: {{ section.settings.card_badge_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .store-activities-{{ section.id }} .sa-card__body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .store-activities-{{ section.id }} .sa-card__title {
    color: var(--sa-title-color);
    font-family: var(--sa-heading-font);
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 500;
    line-height: 1.35;
    margin: 0 0 14px 0;
  }

  .store-activities-{{ section.id }} .sa-card__desc {
    color: var(--sa-card-desc-color);
    font-size: {{ section.settings.card_desc_size }}px;
    line-height: 1.65;
    margin: 0;
  }

  .store-activities-{{ section.id }} .sa-card__footer {
    margin-top: 32px;
    padding-top: 16px;
  }

  .store-activities-{{ section.id }} .sa-card__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--sa-link-color);
    font-size: {{ section.settings.card_link_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .store-activities-{{ section.id }} .sa-card__link:hover {
    color: var(--sa-link-hover-color);
    gap: 12px;
  }

  .store-activities-{{ section.id }} .sa-card__link-arrow {
    transition: transform 0.3s ease;
  }

  .store-activities-{{ section.id }} .sa-card__link:hover .sa-card__link-arrow {
    transform: translateX(4px);
  }

  /* Responsive Tablet & Mobile */
  @media screen and (max-width: 1024px) {
    .store-activities-{{ section.id }} .sa-grid {
      grid-template-columns: repeat({{ section.settings.grid_columns_tablet }}, 1fr);
      gap: {{ section.settings.grid_gap | times: 0.8 }}px;
    }
    .store-activities-{{ section.id }} .sa-heading {
      font-size: {{ section.settings.heading_size_desktop | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .store-activities-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.65 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.65 }}px;
    }
    
    .store-activities-{{ section.id }} .sa-container {
      padding: 0 16px;
    }

    .store-activities-{{ section.id }} .sa-heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    .store-activities-{{ section.id }} .sa-subtitle {
      font-size: {{ section.settings.subtitle_size | minus: 1 }}px;
    }

    .store-activities-{{ section.id }} .sa-card__date {
      font-size: {{ section.settings.date_size_mobile }}px;
    }

    .store-activities-{{ section.id }} .sa-card {
      padding: {{ section.settings.card_padding | times: 0.8 }}px;
    }

    /* Mobile Grid vs Carousel layout options */
    .store-activities-{{ section.id }} .sa-grid.sa-mobile-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      margin-left: -16px;
      margin-right: -16px;
      padding-left: 16px;
      padding-right: 16px;
      gap: 14px;
    }

    .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel::-webkit-scrollbar {
      display: none;
    }

    .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel .sa-card {
      flex: 0 0 82vw;
      scroll-snap-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Hoạt động Cửa hàng",
  "tag": "section",
  "class": "section-store-activities",
  "settings": [
    {
