{% comment %}
  Store Activities / Events Section - Responsive & Fully Customizable
  Created for HELIOS (4 Days - 4 Touch Activities)
{% endcomment %}

<section class="store-activities-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.import_gothic_font -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&display=swap" rel="stylesheet">
  {%- endif -%}

  <style>
    .store-activities-{{ section.id }} {
      --sa-bg: {{ section.settings.section_bg }};
      --sa-card-bg: {{ section.settings.card_bg }};
      --sa-card-border: {{ section.settings.card_border }};
      --sa-subtitle-color: {{ section.settings.subtitle_color }};
      --sa-heading-color: {{ section.settings.heading_color }};
      --sa-desc-color: {{ section.settings.description_color }};
      --sa-date-color: {{ section.settings.date_color }};
      --sa-badge-color: {{ section.settings.card_badge_color }};
      --sa-title-color: {{ section.settings.card_title_color }};
      --sa-card-desc-color: {{ section.settings.card_desc_color }};
      --sa-link-color: {{ section.settings.card_link_color }};
      --sa-link-hover-color: {{ section.settings.card_link_hover_color }};
      
      --sa-date-font: {% if section.settings.date_font_custom != blank %}{{ section.settings.date_font_custom }}{% elsif section.settings.import_gothic_font %}'Cinzel Decorative', 'Pirata One', Georgia, serif{% else %}inherit{% endif %};
      --sa-heading-font: {% if section.settings.heading_font_custom != blank %}{{ section.settings.heading_font_custom }}{% else %}var(--heading-font-stack, inherit){% endif %};

      display: block !important;
      width: 100% !important;
      clear: both !important;
      box-sizing: border-box !important;
      background-color: var(--sa-bg) !important;
      padding-top: {{ section.settings.padding_top }}px !important;
      padding-bottom: {{ section.settings.padding_bottom }}px !important;
      position: relative !important;
      overflow: hidden !important;
    }

    .store-activities-{{ section.id }} *,
    .store-activities-{{ section.id }} *::before,
    .store-activities-{{ section.id }} *::after {
      box-sizing: border-box;
    }

    .store-activities-{{ section.id }} .sa-container {
      display: block !important;
      width: 100% !important;
      max-width: {{ section.settings.max_width }}px !important;
      margin: 0 auto !important;
      padding: 0 24px !important;
      clear: both !important;
      float: none !important;
    }

    /* Header Styles */
    .store-activities-{{ section.id }} .sa-header {
      display: block !important;
      width: 100% !important;
      float: none !important;
      clear: both !important;
      margin: 0 0 {{ section.settings.header_spacing }}px 0 !important;
    }
    .store-activities-{{ section.id }} .sa-align-left { text-align: left !important; }
    .store-activities-{{ section.id }} .sa-align-center { text-align: center !important; }
    .store-activities-{{ section.id }} .sa-align-right { text-align: right !important; }

    .store-activities-{{ section.id }} .sa-subtitle {
      display: block !important;
      color: var(--sa-subtitle-color) !important;
      font-size: {{ section.settings.subtitle_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: {{ section.settings.subtitle_letter_spacing }}px !important;
      text-transform: uppercase !important;
      margin: 0 0 16px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-heading {
      display: block !important;
      color: var(--sa-heading-color) !important;
      font-family: var(--sa-heading-font) !important;
      font-size: {{ section.settings.heading_size_desktop }}px !important;
      font-weight: 400 !important;
      line-height: 1.25 !important;
      margin: 0 0 16px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-description {
      display: block !important;
      color: var(--sa-desc-color) !important;
      font-size: {{ section.settings.description_size }}px !important;
      line-height: 1.6 !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
    .store-activities-{{ section.id }} .sa-desc-italic {
      font-style: italic !important;
    }

    /* Grid & Cards */
    .store-activities-{{ section.id }} .sa-grid {
      display: grid !important;
      grid-template-columns: repeat({{ section.settings.grid_columns_desktop }}, minmax(0, 1fr)) !important;
      gap: {{ section.settings.grid_gap }}px !important;
      align-items: stretch !important;
      width: 100% !important;
      float: none !important;
      clear: both !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .store-activities-{{ section.id }} .sa-card {
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      width: 100% !important;
      height: 100% !important;
      min-height: 220px !important;
      float: none !important;
      position: relative !important;
      opacity: 1 !important;
      visibility: visible !important;
      background-color: var(--sa-card-bg) !important;
      border: 1px solid var(--sa-card-border) !important;
      border-radius: {{ section.settings.card_border_radius }}px !important;
      padding: {{ section.settings.card_padding }}px !important;
      transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease !important;
      margin: 0 !important;
      top: auto !important;
      right: auto !important;
      bottom: auto !important;
      left: auto !important;
      z-index: 1 !important;
    }

    .store-activities-{{ section.id }} .sa-card--hover:hover {
      border-color: var(--sa-link-color) !important;
      transform: translateY(-4px) !important;
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4) !important;
    }

    .store-activities-{{ section.id }} .sa-card__header {
      display: block !important;
      margin: 0 0 24px 0 !important;
      width: 100% !important;
    }

    .store-activities-{{ section.id }} .sa-card__date {
      display: block !important;
      color: var(--sa-date-color) !important;
      font-family: var(--sa-date-font) !important;
      font-size: {{ section.settings.date_size_desktop }}px !important;
      font-weight: 700 !important;
      line-height: 1.1 !important;
      margin: 0 0 8px 0 !important;
      letter-spacing: -0.02em !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-card__badge {
      display: block !important;
      color: var(--sa-badge-color) !important;
      font-size: {{ section.settings.card_badge_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: 1.5px !important;
      text-transform: uppercase !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-card__body {
      display: flex !important;
      flex-direction: column !important;
      flex-grow: 1 !important;
      width: 100% !important;
    }

    .store-activities-{{ section.id }} .sa-card__title {
      display: block !important;
      color: var(--sa-title-color) !important;
      font-family: var(--sa-heading-font) !important;
      font-size: {{ section.settings.card_title_size }}px !important;
      font-weight: 500 !important;
      line-height: 1.35 !important;
      margin: 0 0 14px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-card__desc {
      display: block !important;
      color: var(--sa-card-desc-color) !important;
      font-size: {{ section.settings.card_desc_size }}px !important;
      line-height: 1.65 !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-card__footer {
      display: block !important;
      margin: 32px 0 0 0 !important;
      padding-top: 16px !important;
      width: 100% !important;
    }

    .store-activities-{{ section.id }} .sa-card__link {
      display: inline-flex !important;
      align-items: center !important;
      gap: 8px !important;
      color: var(--sa-link-color) !important;
      font-size: {{ section.settings.card_link_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: 1.5px !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      transition: color 0.3s ease, gap 0.3s ease !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .store-activities-{{ section.id }} .sa-card__link:hover {
      color: var(--sa-link-hover-color) !important;
      gap: 12px !important;
    }

    .store-activities-{{ section.id }} .sa-card__link-arrow {
      display: inline-block !important;
      transition: transform 0.3s ease !important;
    }

    .store-activities-{{ section.id }} .sa-card__link:hover .sa-card__link-arrow {
      transform: translateX(4px) !important;
    }

    .store-activities-{{ section.id }} .sa-card,
    .store-activities-{{ section.id }} .sa-card__header,
    .store-activities-{{ section.id }} .sa-card__date,
    .store-activities-{{ section.id }} .sa-card__badge,
    .store-activities-{{ section.id }} .sa-card__body,
    .store-activities-{{ section.id }} .sa-card__title,
    .store-activities-{{ section.id }} h3.sa-card__title,
    .store-activities-{{ section.id }} .sa-card__desc,
    .store-activities-{{ section.id }} .sa-card__footer {
      text-align: {{ section.settings.card_text_align | default: 'left' }} !important;
    }

    /* Responsive Tablet & Mobile */
    @media screen and (max-width: 1024px) {
      .store-activities-{{ section.id }} .sa-grid {
        grid-template-columns: repeat({{ section.settings.grid_columns_tablet }}, minmax(0, 1fr)) !important;
        gap: {{ section.settings.grid_gap | times: 0.8 }}px !important;
      }
      .store-activities-{{ section.id }} .sa-heading {
        font-size: {{ section.settings.heading_size_desktop | times: 0.85 }}px !important;
      }
    }

    @media screen and (max-width: 749px) {
      .store-activities-{{ section.id }} {
        padding-top: {{ section.settings.padding_top | times: 0.65 }}px !important;
        padding-bottom: {{ section.settings.padding_bottom | times: 0.65 }}px !important;
      }
      
      .store-activities-{{ section.id }} .sa-container {
        padding: 0 16px !important;
      }

      .store-activities-{{ section.id }} .sa-heading {
        font-size: {{ section.settings.heading_size_mobile }}px !important;
      }

      .store-activities-{{ section.id }} .sa-subtitle {
        font-size: {{ section.settings.subtitle_size | minus: 1 }}px !important;
      }

      .store-activities-{{ section.id }} .sa-card__date {
        font-size: {{ section.settings.date_size_mobile }}px !important;
      }

      .store-activities-{{ section.id }} .sa-card {
        padding: {{ section.settings.card_padding | times: 0.8 }}px !important;
        min-height: 180px !important;
      }

      /* Mobile Grid vs Carousel layout options */
      .store-activities-{{ section.id }} .sa-grid.sa-mobile-grid {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) !important;
        gap: 16px !important;
      }

      .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel {
        display: flex !important;
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
        scroll-snap-type: x mandatory !important;
        scrollbar-width: none !important;
        -webkit-overflow-scrolling: touch !important;
        margin-left: -16px !important;
        margin-right: -16px !important;
        padding-left: 16px !important;
        padding-right: 16px !important;
        gap: 14px !important;
      }

      .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel::-webkit-scrollbar {
        display: none !important;
      }

      .store-activities-{{ section.id }} .sa-grid.sa-mobile-carousel .sa-card {
        flex: 0 0 82vw !important;
        width: 82vw !important;
        scroll-snap-align: center !important;
      }
    }
  </style>

  <div class="sa-container">
    {%- if section.settings.subtitle != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <header class="sa-header sa-align-{{ section.settings.header_align }}">
        {%- if section.settings.subtitle != blank -%}
          <div class="sa-subtitle">{{ section.settings.subtitle }}</div>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="sa-heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <div class="sa-description {% if section.settings.description_italic %}sa-desc-italic{% endif %}">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="sa-grid sa-mobile-{{ section.settings.mobile_layout }}">
      {%- for block in section.blocks -%}
        <div class="sa-card {% if section.settings.card_hover_effect %}sa-card--hover{% endif %}" {{ block.shopify_attributes }}
             {% if block.settings.custom_card_bg != blank or block.settings.custom_border_color != blank %}
               style="{% if block.settings.custom_card_bg != blank %}--sa-card-bg: {{ block.settings.custom_card_bg }};{% endif %} {% if block.settings.custom_border_color != blank %}--sa-card-border: {{ block.settings.custom_border_color }};{% endif %}"
             {% endif %}>
          
          <div class="sa-card__header">
            {%- if block.settings.date != blank -%}
              <div class="sa-card__date">{{ block.settings.date }}</div>
            {%- endif -%}
            
            {%- if block.settings.badge != blank -%}
              <div class="sa-card__badge">{{ block.settings.badge }}</div>
            {%- endif -%}
          </div>

          <div class="sa-card__body">
            {%- if block.settings.title != blank -%}
              <h3 class="sa-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.description != blank -%}
              <div class="sa-card__desc">{{ block.settings.description }}</div>
            {%- endif -%}
          </div>

          {%- if block.settings.link_label != blank -%}
            <div class="sa-card__footer">
              <a href="{{ block.settings.link_url | default: '#' }}" class="sa-card__link" {% if block.settings.link_url == blank %}aria-disabled="true"{% endif %}>
                <span>{{ block.settings.link_label }}</span>
                <span class="sa-card__link-arrow">→</span>
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hoạt động Cửa hàng",
  "tag": "section",
  "class": "section-store-activities",
  "settings": [
    {
      "type": "header",
      "content": "Bố cục & Khoảng cách"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Khoảng cách trên (Desktop)",
      "min": 20,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Khoảng cách dưới (Desktop)",
      "min": 20,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Chiều rộng tối đa (Max Width)",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Cấu hình Grid / Responsive"
    },
    {
      "type": "range",
      "id": "grid_columns_desktop",
      "label": "Số cột Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
      "label": "Số cột Tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Bố cục trên Mobile",
      "options": [
        { "value": "grid", "label": "Xếp chồng (1 cột dọc)" },
        { "value": "carousel", "label": "Vuốt ngang (Carousel lướt thẻ)" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Khoảng cách giữa các thẻ (Gap)",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Nội dung Header"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Căn lề Header",
      "options": [
        { "value": "left", "label": "Trái" },
        { "value": "center", "label": "Giữa" },
        { "value": "right", "label": "Phải" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Khoảng cách từ Header xuống thẻ",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Dòng phụ đề (Eyebrow)",
      "default": "SỰ KIỆN - BỐN HOẠT ĐỘNG TẠI CỬA HÀNG"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Màu phụ đề",
      "default": "#b58c5a"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Cỡ chữ phụ đề",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "subtitle_letter_spacing",
      "label": "Khoảng cách chữ phụ đề (Letter Spacing)",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề chính",
      "default": "Bốn ngày. Bốn hoạt động chạm được."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Màu tiêu đề chính",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading_font_custom",
      "label": "Custom Font Family Tiêu đề (tùy chọn)",
      "placeholder": "VD: 'Times New Roman', serif"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Cỡ chữ Tiêu đề (Desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Cỡ chữ Tiêu đề (Mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Mô tả nhỏ dưới tiêu đề",
      "default": "Không chỉ mua. Đến cửa hàng để trải nghiệm mười năm bằng tay."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Màu mô tả",
      "default": "#a8a8a8"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Cỡ chữ mô tả",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "description_italic",
      "label": "In nghiêng mô tả",
      "default": true
    },
    {
      "type": "header",
      "content": "Tùy chỉnh thẻ (Card Style)"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Màu nền Section",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Màu nền thẻ (Card Background)",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Màu viền thẻ (Card Border)",
      "default": "#2a221b"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding bên trong thẻ",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Độ bo góc thẻ (Border Radius)",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "card_hover_effect",
      "label": "Hiệu ứng khi di chuột (Hover Effect)",
      "default": true
    },
    {
      "type": "select",
      "id": "card_text_align",
      "label": "Căn lề chữ trong Thẻ (Card Text Align)",
      "options": [
        { "value": "left", "label": "Trái (Left)" },
        { "value": "center", "label": "Giữa (Center)" },
        { "value": "right", "label": "Phải (Right)" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Typography Thẻ (Ngày & Badge)"
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Màu ngày tháng (05.08, 06.08...)",
      "default": "#cd6b32"
    },
    {
      "type": "checkbox",
      "id": "import_gothic_font",
      "label": "Tự động tải Font chữ Gothic/Ornamental cho Ngày",
      "default": true
    },
    {
      "type": "text",
      "id": "date_font_custom",
      "label": "Custom Font Family Ngày (nếu có riêng)",
      "placeholder": "VD: 'Pirata One', serif"
    },
    {
      "type": "range",
      "id": "date_size_desktop",
      "label": "Cỡ chữ Ngày (Desktop)",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "date_size_mobile",
      "label": "Cỡ chữ Ngày (Mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "card_badge_color",
      "label": "Màu Badge/Sub-date (THỨ BA - CHỈ MEMBER...)",
