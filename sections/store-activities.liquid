      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Khoảng cách dưới (Desktop)",
      "min": 20,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Chiều rộng tối đa (Max Width)",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Cấu hình Grid / Responsive"
    },
    {
      "type": "range",
      "id": "grid_columns_desktop",
      "label": "Số cột Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
