{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magazine-editorial-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-magazine-editorial__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-magazine-editorial__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: stretch;
  }

  .ai-magazine-editorial__feature-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
    overflow: hidden;
  }

  .ai-magazine-editorial__feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 600px;
    object-fit: cover;
    display: block;
  }

  .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 600px;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  .ai-magazine-editorial__feature-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: {{ block.settings.overlay_padding }}px;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
  }

  .ai-magazine-editorial__feature-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_font_size }}px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 12px;
    font-weight: 600;
  }

  .ai-magazine-editorial__feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 16px;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-magazine-editorial__feature-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.excerpt_font_size }}px;
    color: {{ block.settings.excerpt_color }};
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-magazine-editorial__feature-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: gap 0.3s ease;
  }

  .ai-magazine-editorial__feature-link-{{ ai_gen_id }}:hover {
    gap: 12px;
  }

  .ai-magazine-editorial__feature-link-arrow-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-magazine-editorial__feature-link-{{ ai_gen_id }}:hover .ai-magazine-editorial__feature-link-arrow-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-magazine-editorial__sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-magazine-editorial__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    display: flex;
    flex-direction: column;
  }

  .ai-magazine-editorial__card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .ai-magazine-editorial__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ai-magazine-editorial__card-{{ ai_gen_id }}:hover .ai-magazine-editorial__card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-magazine-editorial__card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-magazine-editorial__card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-magazine-editorial__card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-magazine-editorial__card-category-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_category_size }}px;
    color: {{ block.settings.category_color }};
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .ai-magazine-editorial__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    line-height: 1.3;
    font-weight: 600;
  }

  .ai-magazine-editorial__card-excerpt-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_excerpt_size }}px;
    color: {{ block.settings.card_excerpt_color }};
    line-height: 1.5;
    margin-bottom: 16px;
    flex-grow: 1;
  }

  .ai-magazine-editorial__card-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.card_link_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.3s ease;
  }

  .ai-magazine-editorial__card-link-{{ ai_gen_id }}:hover {
    gap: 10px;
  }

  .ai-magazine-editorial__card-link-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .ai-magazine-editorial__card-link-{{ ai_gen_id }}:hover .ai-magazine-editorial__card-link-arrow-{{ ai_gen_id }} {
    transform: translateX(3px);
  }

  @media screen and (max-width: 989px) {
    .ai-magazine-editorial__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-magazine-editorial__feature-{{ ai_gen_id }},
    .ai-magazine-editorial__sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-magazine-editorial__feature-image-{{ ai_gen_id }},
    .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-magazine-editorial__feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.75 }}px;
    }

    .ai-magazine-editorial__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-magazine-editorial-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 0;
    }

    .ai-magazine-editorial__container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-magazine-editorial__feature-image-{{ ai_gen_id }},
    .ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }

    .ai-magazine-editorial__feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.6 }}px;
    }

    .ai-magazine-editorial__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.8 }}px;
    }

    .ai-magazine-editorial__overlay-padding-{{ ai_gen_id }} {
      padding: {{ block.settings.overlay_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<magazine-editorial-{{ ai_gen_id }} class="ai-magazine-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magazine-editorial__container-{{ ai_gen_id }}">
    <div class="ai-magazine-editorial__grid-{{ ai_gen_id }}">
      <div class="ai-magazine-editorial__feature-{{ ai_gen_id }}">
        {% if block.settings.feature_image %}
          <img
            src="{{ block.settings.feature_image | image_url: width: 1400 }}"
            alt="{{ block.settings.feature_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.feature_image.width }}"
            height="{{ block.settings.feature_image.height }}"
            class="ai-magazine-editorial__feature-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-magazine-editorial__feature-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_feature_overlay %}
          <div class="ai-magazine-editorial__feature-overlay-{{ ai_gen_id }}">
            {% if block.settings.feature_category != blank %}
              <div class="ai-magazine-editorial__feature-category-{{ ai_gen_id }}">
                {{ block.settings.feature_category }}
              </div>
            {% endif %}

            {% if block.settings.feature_title != blank %}
              <h2 class="ai-magazine-editorial__feature-title-{{ ai_gen_id }}">
                {{ block.settings.feature_title }}
              </h2>
            {% endif %}

            {% if block.settings.feature_excerpt != blank %}
              <div class="ai-magazine-editorial__feature-excerpt-{{ ai_gen_id }}">
                {{ block.settings.feature_excerpt }}
              </div>
            {% endif %}

            {% if block.settings.feature_link != blank %}
              <a href="{{ block.settings.feature_link }}" class="ai-magazine-editorial__feature-link-{{ ai_gen_id }}">
                {{ block.settings.feature_link_text }}
                <svg class="ai-magazine-editorial__feature-link-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <div class="ai-magazine-editorial__sidebar-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign card_image_key = 'card_' | append: i | append: '_image'
            assign card_category_key = 'card_' | append: i | append: '_category'
            assign card_title_key = 'card_' | append: i | append: '_title'
            assign card_excerpt_key = 'card_' | append: i | append: '_excerpt'
            assign card_link_key = 'card_' | append: i | append: '_link'
            assign card_link_text_key = 'card_' | append: i | append: '_link_text'

            assign card_image = block.settings[card_image_key]
            assign card_category = block.settings[card_category_key]
            assign card_title = block.settings[card_title_key]
            assign card_excerpt = block.settings[card_excerpt_key]
            assign card_link = block.settings[card_link_key]
            assign card_link_text = block.settings[card_link_text_key]
          %}

          <div class="ai-magazine-editorial__card-{{ ai_gen_id }}">
            <div class="ai-magazine-editorial__card-image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 800 }}"
                  alt="{{ card_image.alt | escape }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                  class="ai-magazine-editorial__card-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-magazine-editorial__card-placeholder-{{ ai_gen_id }}">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-magazine-editorial__card-content-{{ ai_gen_id }}">
              {% if card_category != blank %}
                <div class="ai-magazine-editorial__card-category-{{ ai_gen_id }}">
                  {{ card_category }}
                </div>
              {% endif %}

              {% if card_title != blank %}
                <h3 class="ai-magazine-editorial__card-title-{{ ai_gen_id }}">
                  {{ card_title }}
                </h3>
              {% endif %}

              {% if card_excerpt != blank %}
                <div class="ai-magazine-editorial__card-excerpt-{{ ai_gen_id }}">
                  {{ card_excerpt }}
                </div>
              {% endif %}

              {% if card_link != blank %}
                <a href="{{ card_link }}" class="ai-magazine-editorial__card-link-{{ ai_gen_id }}">
                  {{ card_link_text }}
                  <svg class="ai-magazine-editorial__card-link-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</magazine-editorial-{{ ai_gen_id }}>

<script>
  (function() {
    class MagazineEditorial{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initLazyLoad();
      }

      initLazyLoad() {
        const images = this.querySelectorAll('img[loading="lazy"]');
        
        if ('IntersectionObserver' in window) {
          const imageObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const img = entry.target;
                img.src = img.src;
                observer.unobserve(img);
              }
            });
          });

          images.forEach(img => imageObserver.observe(img));
        }
      }
    }

    customElements.define('magazine-editorial-{{ ai_gen_id }}', MagazineEditorial{{ ai_gen_id }});
  })();
</script>

