{% comment %}
  Store Activities / Events Block - Responsive & Fully Customizable
  Created for HELIOS (4 Days - 4 Touch Activities)
  Can be used inside _blocks container or section blocks.
{% endcomment %}
{% assign sa_id = block.id | replace: '_', '' | downcase %}

<div class="store-activities-block-{{ sa_id }}" {{ block.shopify_attributes }}>
  <div class="sa-container-{{ sa_id }}">
    {%- if block.settings.subtitle != blank or block.settings.heading != blank or block.settings.description != blank -%}
      <header class="sa-header-{{ sa_id }} sa-align-{{ block.settings.header_align }}">
        {%- if block.settings.subtitle != blank -%}
          <div class="sa-subtitle-{{ sa_id }}">{{ block.settings.subtitle }}</div>
        {%- endif -%}
        
        {%- if block.settings.heading != blank -%}
          <h2 class="sa-heading-{{ sa_id }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if block.settings.description != blank -%}
          <div class="sa-description-{{ sa_id }} {% if block.settings.description_italic %}sa-desc-italic-{{ sa_id }}{% endif %}">
            {{ block.settings.description }}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="sa-grid-{{ sa_id }} sa-mobile-{{ block.settings.mobile_layout }}">
      {%- for i in (1..4) -%}
        {%- liquid
          assign date_key = 'date_' | append: i
          assign badge_key = 'badge_' | append: i
          assign title_key = 'title_' | append: i
          assign desc_key = 'desc_' | append: i
          assign label_key = 'link_label_' | append: i
          assign url_key = 'link_url_' | append: i
          
          assign date_val = block.settings[date_key]
          assign badge_val = block.settings[badge_key]
          assign title_val = block.settings[title_key]
          assign desc_val = block.settings[desc_key]
          assign label_val = block.settings[label_key]
          assign url_val = block.settings[url_key]
        -%}

        {%- if date_val != blank or title_val != blank -%}
          <div class="sa-card-{{ sa_id }} {% if block.settings.card_hover_effect %}sa-card--hover-{{ sa_id }}{% endif %}">
            <div class="sa-card__header-{{ sa_id }}">
              {%- if date_val != blank -%}
                <div class="sa-card__date-{{ sa_id }}">{{ date_val }}</div>
              {%- endif -%}
              
              {%- if badge_val != blank -%}
                <div class="sa-card__badge-{{ sa_id }}">{{ badge_val }}</div>
              {%- endif -%}
            </div>

            <div class="sa-card__body-{{ sa_id }}">
              {%- if title_val != blank -%}
                <h3 class="sa-card__title-{{ sa_id }}">{{ title_val }}</h3>
              {%- endif -%}
              
              {%- if desc_val != blank -%}
                <div class="sa-card__desc-{{ sa_id }}">{{ desc_val }}</div>
              {%- endif -%}
            </div>

            {%- if label_val != blank -%}
              <div class="sa-card__footer-{{ sa_id }}">
                <a href="{{ url_val | default: '#' }}" class="sa-card__link-{{ sa_id }}" {% if url_val == blank %}aria-disabled="true"{% endif %}>
                  <span>{{ label_val }}</span>
                  <span class="sa-card__link-arrow-{{ sa_id }}">→</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if block.settings.import_gothic_font -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&display=swap" rel="stylesheet">
{%- endif -%}

<style>
  .store-activities-block-{{ sa_id }} {
    --sa-bg: {{ block.settings.section_bg }};
    --sa-card-bg: {{ block.settings.card_bg }};
    --sa-card-border: {{ block.settings.card_border }};
    --sa-subtitle-color: {{ block.settings.subtitle_color }};
    --sa-heading-color: {{ block.settings.heading_color }};
    --sa-desc-color: {{ block.settings.description_color }};
    --sa-date-color: {{ block.settings.date_color }};
    --sa-badge-color: {{ block.settings.card_badge_color }};
    --sa-title-color: {{ block.settings.card_title_color }};
    --sa-card-desc-color: {{ block.settings.card_desc_color }};
    --sa-link-color: {{ block.settings.card_link_color }};
    --sa-link-hover-color: {{ block.settings.card_link_hover_color }};
    
    --sa-date-font: {% if block.settings.date_font_custom != blank %}{{ block.settings.date_font_custom }}{% elsif block.settings.import_gothic_font %}'Cinzel Decorative', 'Pirata One', Georgia, serif{% else %}inherit{% endif %};
    --sa-heading-font: {% if block.settings.heading_font_custom != blank %}{{ block.settings.heading_font_custom }}{% else %}var(--heading-font-stack, inherit){% endif %};

    width: {{ block.settings.desktop_width_percent }}%;
    background-color: var(--sa-bg);
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .sa-container-{{ sa_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header Styles */
  .sa-header-{{ sa_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }
  .store-activities-block-{{ sa_id }} .sa-align-left { text-align: left; }
  .store-activities-block-{{ sa_id }} .sa-align-center { text-align: center; }
  .store-activities-block-{{ sa_id }} .sa-align-right { text-align: right; }

  .sa-subtitle-{{ sa_id }} {
    color: var(--sa-subtitle-color);
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: 600;
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .sa-heading-{{ sa_id }} {
    color: var(--sa-heading-color);
    font-family: var(--sa-heading-font);
    font-size: {{ block.settings.heading_size_desktop }}px;
    font-weight: 400;
    line-height: 1.25;
    margin: 0 0 16px 0;
  }

  .sa-description-{{ sa_id }} {
    color: var(--sa-desc-color);
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0;
  }
  .sa-desc-italic-{{ sa_id }} {
    font-style: italic;
  }

  /* Grid & Cards */
  .sa-grid-{{ sa_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: stretch;
  }

  .sa-card-{{ sa_id }} {
    background-color: var(--sa-card-bg);
    border: 1px solid var(--sa-card-border);
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
    height: 100%;
  }

  .sa-card--hover-{{ sa_id }}:hover {
    border-color: var(--sa-link-color);
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4);
  }

  .sa-card__header-{{ sa_id }} {
    margin-bottom: 24px;
  }

  .sa-card__date-{{ sa_id }} {
    color: var(--sa-date-color);
    font-family: var(--sa-date-font);
    font-size: {{ block.settings.date_size_desktop }}px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }

  .sa-card__badge-{{ sa_id }} {
    color: var(--sa-badge-color);
    font-size: {{ block.settings.card_badge_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .sa-card__body-{{ sa_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .sa-card__title-{{ sa_id }} {
    color: var(--sa-title-color);
    font-family: var(--sa-heading-font);
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 500;
    line-height: 1.35;
    margin: 0 0 14px 0;
  }

  .sa-card__desc-{{ sa_id }} {
    color: var(--sa-card-desc-color);
    font-size: {{ block.settings.card_desc_size }}px;
    line-height: 1.65;
    margin: 0;
  }

  .sa-card__footer-{{ sa_id }} {
    margin-top: 32px;
    padding-top: 16px;
  }

  .sa-card__link-{{ sa_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--sa-link-color);
    font-size: {{ block.settings.card_link_size }}px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.3s ease, gap 0.3s ease;
  }

  .sa-card__link-{{ sa_id }}:hover {
    color: var(--sa-link-hover-color);
    gap: 12px;
  }

  .sa-card__link-arrow-{{ sa_id }} {
    transition: transform 0.3s ease;
  }

  .sa-card__link-{{ sa_id }}:hover .sa-card__link-arrow-{{ sa_id }} {
    transform: translateX(4px);
  }

  /* Responsive Tablet & Mobile */
  @media screen and (max-width: 1024px) {
    .sa-grid-{{ sa_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.8 }}px;
    }
    .sa-heading-{{ sa_id }} {
      font-size: {{ block.settings.heading_size_desktop | times: 0.85 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .store-activities-block-{{ sa_id }} {
      padding-top: {{ block.settings.padding_top | times: 0.65 }}px;
      padding-bottom: {{ block.settings.padding_bottom | times: 0.65 }}px;
      width: 100%;
    }
    
    .sa-container-{{ sa_id }} {
      padding: 0 16px;
    }

    .sa-heading-{{ sa_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .sa-subtitle-{{ sa_id }} {
      font-size: {{ block.settings.subtitle_size | minus: 1 }}px;
    }

    .sa-card__date-{{ sa_id }} {
      font-size: {{ block.settings.date_size_mobile }}px;
    }

    .sa-card-{{ sa_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    /* Mobile Grid vs Carousel layout options */
    .sa-grid-{{ sa_id }}.sa-mobile-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .sa-grid-{{ sa_id }}.sa-mobile-carousel {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      margin-left: -16px;
      margin-right: -16px;
      padding-left: 16px;
      padding-right: 16px;
      gap: 14px;
    }

    .sa-grid-{{ sa_id }}.sa-mobile-carousel::-webkit-scrollbar {
      display: none;
    }

    .sa-grid-{{ sa_id }}.sa-mobile-carousel .sa-card-{{ sa_id }} {
      flex: 0 0 82vw;
      scroll-snap-align: center;
    }
  }
</style>

