{% comment %}
  Store Activities / Events Block - Responsive & Fully Customizable
  Created for HELIOS (4 Days - 4 Touch Activities)
  Can be used inside _blocks container or section blocks.
{% endcomment %}
{% assign sa_id = block.id | replace: '_', '-' %}

{%- if block.settings.import_gothic_font -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&display=swap" rel="stylesheet">
{%- endif -%}

<div class="sa-block-wrapper-{{ sa_id }}" {{ block.shopify_attributes }}>
  <style>
    .sa-block-wrapper-{{ sa_id }} {
      --sa-bg: {{ block.settings.section_bg }};
      --sa-card-bg: {{ block.settings.card_bg }};
      --sa-card-border: {{ block.settings.card_border }};
      --sa-subtitle-color: {{ block.settings.subtitle_color }};
      --sa-heading-color: {{ block.settings.heading_color }};
      --sa-desc-color: {{ block.settings.description_color }};
      --sa-date-color: {{ block.settings.date_color }};
      --sa-badge-color: {{ block.settings.card_badge_color }};
      --sa-title-color: {{ block.settings.card_title_color }};
      --sa-card-desc-color: {{ block.settings.card_desc_color }};
      --sa-link-color: {{ block.settings.card_link_color }};
      --sa-link-hover-color: {{ block.settings.card_link_hover_color }};
      
      --sa-date-font: {% if block.settings.date_font_custom != blank %}{{ block.settings.date_font_custom }}{% elsif block.settings.import_gothic_font %}'Cinzel Decorative', 'Pirata One', Georgia, serif{% else %}inherit{% endif %};
      --sa-heading-font: {% if block.settings.heading_font_custom != blank %}{{ block.settings.heading_font_custom }}{% else %}var(--heading-font-stack, inherit){% endif %};

      display: block !important;
      width: 100% !important;
      clear: both !important;
      box-sizing: border-box !important;
      background-color: var(--sa-bg) !important;
      padding-top: {{ block.settings.padding_top }}px !important;
      padding-bottom: {{ block.settings.padding_bottom }}px !important;
      position: relative !important;
      overflow: hidden !important;
    }

    .sa-block-wrapper-{{ sa_id }} *,
    .sa-block-wrapper-{{ sa_id }} *::before,
    .sa-block-wrapper-{{ sa_id }} *::after {
      box-sizing: border-box;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-container-{{ sa_id }} {
      display: block !important;
      width: 100% !important;
      max-width: {{ block.settings.max_width }}px !important;
      margin: 0 auto !important;
      padding: 0 24px !important;
      clear: both !important;
      float: none !important;
    }

    /* Header Styles */
    .sa-block-wrapper-{{ sa_id }} .sa-header-{{ sa_id }} {
      display: block !important;
      width: 100% !important;
      float: none !important;
      clear: both !important;
      margin: 0 0 {{ block.settings.header_spacing }}px 0 !important;
    }
    .sa-block-wrapper-{{ sa_id }} .sa-align-left { text-align: left !important; }
    .sa-block-wrapper-{{ sa_id }} .sa-align-center { text-align: center !important; }
    .sa-block-wrapper-{{ sa_id }} .sa-align-right { text-align: right !important; }

    .sa-block-wrapper-{{ sa_id }} .sa-subtitle-{{ sa_id }} {
      display: block !important;
      color: var(--sa-subtitle-color) !important;
      font-size: {{ block.settings.subtitle_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: {{ block.settings.subtitle_letter_spacing }}px !important;
      text-transform: uppercase !important;
      margin: 0 0 16px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-heading-{{ sa_id }} {
      display: block !important;
      color: var(--sa-heading-color) !important;
      font-family: var(--sa-heading-font) !important;
      font-size: {{ block.settings.heading_size_desktop }}px !important;
      font-weight: 400 !important;
      line-height: 1.25 !important;
      margin: 0 0 16px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-description-{{ sa_id }} {
      display: block !important;
      color: var(--sa-desc-color) !important;
      font-size: {{ block.settings.description_size }}px !important;
      line-height: 1.6 !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
    .sa-block-wrapper-{{ sa_id }} .sa-desc-italic {
      font-style: italic !important;
    }

    /* Grid & Cards */
    .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }} {
      display: grid !important;
      grid-template-columns: repeat({{ block.settings.grid_columns_desktop }}, minmax(0, 1fr)) !important;
      gap: {{ block.settings.grid_gap }}px !important;
      align-items: stretch !important;
      width: 100% !important;
      float: none !important;
      clear: both !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card-{{ sa_id }} {
      display: flex !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      width: 100% !important;
      height: 100% !important;
      min-height: 220px !important;
      float: none !important;
      position: relative !important;
      opacity: 1 !important;
      visibility: visible !important;
      background-color: var(--sa-card-bg) !important;
      border: 1px solid var(--sa-card-border) !important;
      border-radius: {{ block.settings.card_border_radius }}px !important;
      padding: {{ block.settings.card_padding }}px !important;
      transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease !important;
      margin: 0 !important;
      top: auto !important;
      right: auto !important;
      bottom: auto !important;
      left: auto !important;
      z-index: 1 !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card--hover-{{ sa_id }}:hover {
      border-color: var(--sa-link-color) !important;
      transform: translateY(-4px) !important;
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.4) !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__header-{{ sa_id }} {
      display: block !important;
      margin: 0 0 24px 0 !important;
      width: 100% !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__date-{{ sa_id }} {
      display: block !important;
      color: var(--sa-date-color) !important;
      font-family: var(--sa-date-font) !important;
      font-size: {{ block.settings.date_size_desktop }}px !important;
      font-weight: 700 !important;
      line-height: 1.1 !important;
      margin: 0 0 8px 0 !important;
      letter-spacing: -0.02em !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__badge-{{ sa_id }} {
      display: block !important;
      color: var(--sa-badge-color) !important;
      font-size: {{ block.settings.card_badge_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: 1.5px !important;
      text-transform: uppercase !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__body-{{ sa_id }} {
      display: flex !important;
      flex-direction: column !important;
      flex-grow: 1 !important;
      width: 100% !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__title-{{ sa_id }} {
      display: block !important;
      color: var(--sa-title-color) !important;
      font-family: var(--sa-heading-font) !important;
      font-size: {{ block.settings.card_title_size }}px !important;
      font-weight: 500 !important;
      line-height: 1.35 !important;
      margin: 0 0 14px 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__desc-{{ sa_id }} {
      display: block !important;
      color: var(--sa-card-desc-color) !important;
      font-size: {{ block.settings.card_desc_size }}px !important;
      line-height: 1.65 !important;
      margin: 0 !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__footer-{{ sa_id }} {
      display: block !important;
      margin: 32px 0 0 0 !important;
      padding-top: 16px !important;
      width: 100% !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__link-{{ sa_id }} {
      display: inline-flex !important;
      align-items: center !important;
      gap: 8px !important;
      color: var(--sa-link-color) !important;
      font-size: {{ block.settings.card_link_size }}px !important;
      font-weight: 600 !important;
      letter-spacing: 1.5px !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      transition: color 0.3s ease, gap 0.3s ease !important;
      opacity: 1 !important;
      visibility: visible !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__link-{{ sa_id }}:hover {
      color: var(--sa-link-hover-color) !important;
      gap: 12px !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__link-arrow-{{ sa_id }} {
      display: inline-block !important;
      transition: transform 0.3s ease !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card__link-{{ sa_id }}:hover .sa-card__link-arrow-{{ sa_id }} {
      transform: translateX(4px) !important;
    }

    .sa-block-wrapper-{{ sa_id }} .sa-card-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__header-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__date-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__badge-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__body-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__title-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} h3.sa-card__title-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__desc-{{ sa_id }},
    .sa-block-wrapper-{{ sa_id }} .sa-card__footer-{{ sa_id }} {
      text-align: {{ block.settings.card_text_align | default: 'left' }} !important;
    }

    /* Responsive Tablet & Mobile */
    @media screen and (max-width: 1024px) {
      .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }} {
        grid-template-columns: repeat({{ block.settings.grid_columns_tablet }}, minmax(0, 1fr)) !important;
        gap: {{ block.settings.grid_gap | times: 0.8 }}px !important;
      }
      .sa-block-wrapper-{{ sa_id }} .sa-heading-{{ sa_id }} {
        font-size: {{ block.settings.heading_size_desktop | times: 0.85 }}px !important;
      }
    }

    @media screen and (max-width: 749px) {
      .sa-block-wrapper-{{ sa_id }} {
        padding-top: {{ block.settings.padding_top | times: 0.65 }}px !important;
        padding-bottom: {{ block.settings.padding_bottom | times: 0.65 }}px !important;
      }
      
      .sa-block-wrapper-{{ sa_id }} .sa-container-{{ sa_id }} {
        padding: 0 16px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-heading-{{ sa_id }} {
        font-size: {{ block.settings.heading_size_mobile }}px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-subtitle-{{ sa_id }} {
        font-size: {{ block.settings.subtitle_size | minus: 1 }}px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-card__date-{{ sa_id }} {
        font-size: {{ block.settings.date_size_mobile }}px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-card-{{ sa_id }} {
        padding: {{ block.settings.card_padding | times: 0.8 }}px !important;
        min-height: 180px !important;
      }

      /* Mobile Grid vs Carousel layout options */
      .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }}.sa-mobile-grid {
        display: grid !important;
        grid-template-columns: minmax(0, 1fr) !important;
        gap: 16px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }}.sa-mobile-carousel {
        display: flex !important;
        flex-wrap: nowrap !important;
        overflow-x: auto !important;
        scroll-snap-type: x mandatory !important;
        scrollbar-width: none !important;
        -webkit-overflow-scrolling: touch !important;
        margin-left: -16px !important;
        margin-right: -16px !important;
        padding-left: 16px !important;
        padding-right: 16px !important;
        gap: 14px !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }}.sa-mobile-carousel::-webkit-scrollbar {
        display: none !important;
      }

      .sa-block-wrapper-{{ sa_id }} .sa-grid-{{ sa_id }}.sa-mobile-carousel .sa-card-{{ sa_id }} {
        flex: 0 0 82vw !important;
        width: 82vw !important;
        scroll-snap-align: center !important;
      }
    }
  </style>

  <div class="sa-container-{{ sa_id }}">
    {%- if block.settings.subtitle != blank or block.settings.heading != blank or block.settings.description != blank -%}
      <header class="sa-header-{{ sa_id }} sa-align-{{ block.settings.header_align }}">
        {%- if block.settings.subtitle != blank -%}
          <div class="sa-subtitle-{{ sa_id }}">{{ block.settings.subtitle }}</div>
        {%- endif -%}
        
        {%- if block.settings.heading != blank -%}
          <h2 class="sa-heading-{{ sa_id }}">{{ block.settings.heading }}</h2>
        {%- endif -%}
        
        {%- if block.settings.description != blank -%}
          <div class="sa-description-{{ sa_id }} {% if block.settings.description_italic %}sa-desc-italic{% endif %}">
            {{ block.settings.description }}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="sa-grid-{{ sa_id }} sa-mobile-{{ block.settings.mobile_layout }}">
      {%- assign cards_data = "card_1|card_2|card_3|card_4" | split: "|" -%}
      
      {%- for c in cards_data -%}
        {%- assign date_key = c | append: "_date" -%}
        {%- assign badge_key = c | append: "_badge" -%}
        {%- assign title_key = c | append: "_title" -%}
        {%- assign desc_key = c | append: "_description" -%}
        {%- assign label_key = c | append: "_link_label" -%}
        {%- assign url_key = c | append: "_link_url" -%}

        {%- assign date_val = block.settings[date_key] -%}
        {%- assign badge_val = block.settings[badge_key] -%}
        {%- assign title_val = block.settings[title_key] -%}
        {%- assign desc_val = block.settings[desc_key] -%}
        {%- assign label_val = block.settings[label_key] -%}
        {%- assign url_val = block.settings[url_key] -%}

        {%- if title_val != blank or date_val != blank or desc_val != blank -%}
          <div class="sa-card-{{ sa_id }} {% if block.settings.card_hover_effect %}sa-card--hover-{{ sa_id }}{% endif %}">
            <div class="sa-card__header-{{ sa_id }}">
              {%- if date_val != blank -%}
                <div class="sa-card__date-{{ sa_id }}">{{ date_val }}</div>
              {%- endif -%}
              
              {%- if badge_val != blank -%}
                <div class="sa-card__badge-{{ sa_id }}">{{ badge_val }}</div>
              {%- endif -%}
            </div>

            <div class="sa-card__body-{{ sa_id }}">
              {%- if title_val != blank -%}
                <h3 class="sa-card__title-{{ sa_id }}">{{ title_val }}</h3>
              {%- endif -%}
              
              {%- if desc_val != blank -%}
                <div class="sa-card__desc-{{ sa_id }}">{{ desc_val }}</div>
              {%- endif -%}
            </div>

            {%- if label_val != blank -%}
              <div class="sa-card__footer-{{ sa_id }}">
                <a href="{{ url_val | default: '#' }}" class="sa-card__link-{{ sa_id }}" {% if url_val == blank %}aria-disabled="true"{% endif %}>
                  <span>{{ label_val }}</span>
                  <span class="sa-card__link-arrow-{{ sa_id }}">→</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Block Hoạt động (4 Card)",
  "settings": [
    {
      "type": "header",
      "content": "Bố cục & Khoảng cách"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Khoảng cách trên (Desktop)",
      "min": 20,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Khoảng cách dưới (Desktop)",
      "min": 20,
      "max": 160,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Chiều rộng tối đa (Max Width)",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Cấu hình Grid / Responsive"
    },
    {
      "type": "range",
      "id": "grid_columns_desktop",
      "label": "Số cột Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
      "label": "Số cột Tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Bố cục trên Mobile",
      "options": [
        { "value": "grid", "label": "Xếp chồng (1 cột dọc)" },
        { "value": "carousel", "label": "Vuốt ngang (Carousel lướt thẻ)" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Khoảng cách giữa các thẻ (Gap)",
      "min": 10,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Nội dung Header"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Căn lề Header",
      "options": [
        { "value": "left", "label": "Trái" },
        { "value": "center", "label": "Giữa" },
        { "value": "right", "label": "Phải" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "label": "Khoảng cách từ Header xuống thẻ",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Dòng phụ đề (Eyebrow)",
      "default": "SỰ KIỆN - BỐN HOẠT ĐỘNG TẠI CỬA HÀNG"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Màu phụ đề",
      "default": "#b58c5a"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Cỡ chữ phụ đề",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "subtitle_letter_spacing",
      "label": "Khoảng cách chữ phụ đề (Letter Spacing)",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Tiêu đề chính",
      "default": "Bốn ngày. Bốn hoạt động chạm được."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Màu tiêu đề chính",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading_font_custom",
      "label": "Custom Font Family Tiêu đề (tùy chọn)",
      "placeholder": "VD: 'Times New Roman', serif"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Cỡ chữ Tiêu đề (Desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Cỡ chữ Tiêu đề (Mobile)",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Mô tả nhỏ dưới tiêu đề",
      "default": "Không chỉ mua. Đến cửa hàng để trải nghiệm mười năm bằng tay."
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Màu mô tả",
      "default": "#a8a8a8"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Cỡ chữ mô tả",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "description_italic",
      "label": "In nghiêng mô tả",
      "default": true
    },
    {
      "type": "header",
      "content": "Tùy chỉnh thẻ (Card Style)"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Màu nền Section",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Màu nền thẻ (Card Background)",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Màu viền thẻ (Card Border)",
      "default": "#2a221b"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Padding bên trong thẻ",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Độ bo góc thẻ (Border Radius)",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "card_hover_effect",
      "label": "Hiệu ứng khi di chuột (Hover Effect)",
      "default": true
    },
    {
      "type": "select",
      "id": "card_text_align",
